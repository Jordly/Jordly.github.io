          <span style="color:#475569;flex:1;">${s.name}</span>

          <span style="color:#1e293b;font-weight:600;">${s.count}</span>

          <span style="color:#64748b;">(${s.pct}%)</span>

        </div>`).join('')}

      </div>

    </div>



