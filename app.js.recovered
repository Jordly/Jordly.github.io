        +'</td></tr>';

    }).join('');

  } else if(_systemDataTab === 'handovers' && pageData.length>0){

    rowsHtml = pageData.map(function(h,i){

      var ri = allData.indexOf(h);

      return '<tr>'

        +'<td><input type="checkbox" class="row-checkbox" data-idx="'+ri+'"></td>'

