    performance:EDIT, systemData:VIEW, permissions:HIDE, notifications:VIEW, profile:EDIT

  },

  "客服主�?": {

    dashboard:VOWN, archive:VOWN, target:VOWN, cost:VOWN, operation:permObj(true,true,false,true,false,'own'),

