      +'<select class="fb-select" onchange="filterIssues()" id="issue-filter-assignee" style="flex:1;min-width:120px;max-width:180px;">'

        +'<option value="all">负责�?�?/option>'

        +[...new Set(allItems.filter(function(i){return i.category==='课�?'&&i.assignee;}).map(function(i){return i.assignee;}))].map(function(a){return '<option value="'+a+'">'+a+'</option>';}).join('')

      +'</select>'

      +'<input type="text" id="issue-search" placeholder="搜索课�?描述..." oninput="filterIssues()" style="flex:2;min-width:140px;max-width:240px;padding:7px 12px;border-radius:10px;border:1px solid #d0d7de;font-size:13px;background:linear-gradient(135deg,#f5f3ff,#ede9fe,#dbeafe);color:#334155;">';

  } else {

    filterHtml = ''

      +'<select class="fb-select" onchange="filterIssues()" id="issue-filter-priority" style="flex:1;min-width:100px;max-width:160px;">'

        +'<option value="all">优先�?�?/option><option value="紧�??>紧�??/option><option value="重�?">重�?</option><option value="�?�?>�?�?/option></select>'

      +'<select class="fb-select" onchange="filterIssues()" id="issue-filter-type" style="flex:1;min-width:100px;max-width:160px;">'

        +'<option value="all">类型 �?/option><option value="整改">整改</option><option value="客诉">客诉</option><option value="数据异常">数据异常</option><option value="流程卡点">流程卡点</option><option value="系统故障">系统故障</option><option value="优化">优化</option><option value="其他">其他</option></select>'

      +'<select class="fb-select" onchange="filterIssues()" id="issue-filter-assignee" style="flex:1;min-width:100px;max-width:160px;">'

        +'<option value="all">责任�?�?/option>'

        +[...new Set(allItems.filter(function(i){return(i.category||'�??')==='�??'&&i.assignee;}).map(function(i){return i.assignee;}))].map(function(a){return '<option value="'+a+'">'+a+'</option>';}).join('')

      +'</select>'

      +'<input type="text" id="issue-search" placeholder="搜索�??描述..." oninput="filterIssues()" style="flex:2;min-width:140px;max-width:240px;padding:7px 12px;border-radius:10px;border:1px solid #d0d7de;font-size:13px;background:linear-gradient(135deg,#f0fdf4,#ecfdf5,#dbeafe);color:#334155;">';

  }



  // 图例

  var legendHtml = isTopic

    ? '<div class="issue-legend"><div class="issue-legend-item"><span class="issue-legend-color" style="background:#8b5cf6;"></span> 立项</div><div class="issue-legend-item"><span class="issue-legend-color" style="background:#0B9B96;"></span> 执�?�?/div><div class="issue-legend-item"><span class="issue-legend-color" style="background:#D4AF37;"></span> 结�?</div></div>'

    : '<div class="issue-legend"><div class="issue-legend-item"><span class="issue-legend-color issue-legend-red"></span> 紧�??重�?行高�?/div><div class="issue-legend-item"><span class="issue-legend-color issue-legend-blue"></span> 处理�?/div><div class="issue-legend-item"><span class="issue-legend-color issue-legend-green"></span> 已关�?/div></div>';



  return ''

  // 极光顶部分隔�?  +'<div style="height:3px;background:linear-gradient(90deg,rgba(11,155,150,0.5),rgba(59,130,246,0.5),rgba(139,92,246,0.5));border-radius:0 0 3px 3px;margin-bottom:16px;"></div>'



  // 双标签切�?  +'<div style="display:flex;gap:12px;margin-bottom:16px;">'

    +'<div class="issue-tab-pill '+(issueActiveTab==='issue'?'active':'')+'" onclick="switchIssueTab(\'issue\')" style="flex:1;cursor:pointer;padding:14px 18px;border-radius:14px;text-align:center;transition:all 0.25s;'

      +(issueActiveTab==='issue'?'background:#fff;border:2px solid rgba(11,155,150,0.3);color:#0f766e;box-shadow:0 2px 12px rgba(11,155,150,0.08);':'background:#f8fafc;color:#94a3b8;border:2px solid transparent;')+'">'

      +'<div style="font-size:15px;font-weight:700;">⚠️ �??追踪</div>'

      +'<div style="font-size:11px;margin-top:4px;opacity:0.8;">'+(issueActiveTab==='issue'?'当前活跃 · ':'')+issueTotal+'条�?�?/div>'

    +'</div>'

    +'<div class="issue-tab-pill '+(issueActiveTab==='topic'?'active':'')+'" onclick="switchIssueTab(\'topic\')" style="flex:1;cursor:pointer;padding:14px 18px;border-radius:14px;text-align:center;transition:all 0.25s;'

      +(issueActiveTab==='topic'?'background:#fff;border:2px solid rgba(139,92,246,0.3);color:#6d28d9;box-shadow:0 2px 12px rgba(139,92,246,0.08);':'background:#f8fafc;color:#94a3b8;border:2px solid transparent;')+'">'

      +'<div style="font-size:15px;font-weight:700;">💡 课�?协作</div>'

      +'<div style="font-size:11px;margin-top:4px;opacity:0.8;">'+(issueActiveTab==='topic'?'当前活跃':'点击切换')+' · '+topicTotal+'条�?�?/div>'

    +'</div>'

  +'</div>'



  // 页面描述

  +'<div class="issue-page-header" style="margin-bottom:12px;">'

    +'<div class="issue-page-title-row">'

      +'<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#185FA5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>'

      +'<h1 class="issue-page-title">�??与�?题协�?/h1>'

    +'</div>'

    +'<p class="issue-page-desc">'+(isTopic?'跨团队协同�?题推进�?�流程优化�?�调研诊�??�销�?��升等协作管理':'�??登�?、跟�?���?��管理，支持跨职场协同')+'</p>'

  +'</div>'



