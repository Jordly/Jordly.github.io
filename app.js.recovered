          var hv = HANDOVERS.filter(function(x){return x.status==='已完�?;}).sort(function(a,b){return (b.date||'').localeCompare(a.date||'');}).slice(0,1);

          for (var i=0;i<hv.length;i++) { events.push({type:'transfer',icon:'🔄',label:'PM交接',clr:'#3b82f6',bg:'rgba(59,130,246,0.08)',title:hv[i].projectName+'�?+hv[i].from+' �?'+hv[i].to,detail:'交接日期�?+hv[i].date+' · 状�?�：已完�?,time:hv[i].date||'�?�?}); }

          var cl = ISSUES.filter(function(x){return x.status==='已关�?;}).slice(0,1);

          for (var i=0;i<cl.length;i++) { events.push({type:'done',icon:'�?,label:'�??关闭',clr:'#9ca3af',bg:'rgba(156,163,175,0.08)',title:cl[i].projectName+'�?+cl[i].desc,detail:'关闭人：'+(cl[i].assignee||'系统')+' · 来源�?+(cl[i].source||''),time:'�?�?}); }

          if(events.length===0) return '<div style="text-align:center;padding:20px;color:#9ca3af;font-size:12px;">暂无近期动�??/div>';

          var h='';

          for(var j=0;j<events.length;j++){

            var ev=events[j];

            h+='<div class="tl-item"><div class="tl-dot" style="background:'+ev.clr+';">'+ev.icon+'</div>'+(j<events.length-1?'<div class="tl-line"></div>':'')+'<div class="tl-content"><div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;"><span class="tl-time">'+ev.time+'</span><span class="tl-badge" style="background:'+ev.bg+';color:'+ev.clr+';">'+ev.label+'</span></div><div class="tl-title">'+ev.title+'</div><div class="tl-detail">'+ev.detail+'</div></div></div>';

          }

          return h;

        })()}

