  // 保持高级筛�?�面板的展开状�??  if (_advancedFilterOpen) {

    setTimeout(function(){

      var row = document.getElementById('filter-advanced-row');

      if (row) row.classList.add('show');

      var btn = document.getElementById('fb-adv-toggle');

      if (btn) btn.classList.add('active');

    }, 50);

  }

}

function batchDeleteProjects(){var c=document.querySelectorAll('.archive-row-check:checked');if(!c.length){alert('请先勾�?��?删除的项�?);return}var ids=[];for(var i=0;i<c.length;i++)ids.push(c[i].value);if(!confirm('�?��删除选中�?+ids.length+'�?���?��此操作不�?��复！'))return;ids.forEach(function(id){deleteProjectDirectly(id)});showToast('已删�?+ids.length+'�?���?);renderModule('archive')}

function deleteProjectConfirm(id,name){if(confirm('�?��删除�?+name+'」？仅删此条，不影响其他模块'))deleteProject(id)}

function deleteProjectDirectly(id){PROJECTS=PROJECTS.filter(function(p){return p.id!==id});safeSetItem('chansee_projects',JSON.stringify(PROJECTS));if(window.CloudBaseSync)window.CloudBaseSync.saveAll()}



// ===== �?��与权责�?�?=====



function renderTarget(){



