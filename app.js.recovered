            <defs><linearGradient id="gaugeGrad" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#0B9B96"/><stop offset="60%" stop-color="#00C9A7"/><stop offset="100%" stop-color="#D4AF37"/></linearGradient></defs>

