  // 表格

  +'<div class="issue-table-wrapper">'+tableHtml+'</div>'



  // 图例

  +legendHtml;

}





// ===== �??/课�?详情弹窗 =====

function showIssueDetail(id){

  var item = ISSUES.find(function(i){return i.id===id;});

  if(!item) return;

  var isTopic = item.category === '课�?';

  var overlay = document.getElementById('compare-overlay') || document.createElement('div');

  if(!overlay.id){ overlay.id = 'compare-overlay'; overlay.className = 'modal-overlay'; overlay.style.background='rgba(0,0,0,0.5)'; overlay.style.opacity='1'; document.body.appendChild(overlay); }

  

  var statusColor = item.status==='已关�?||item.status==='结�?'?'#10b981':item.status==='待�?�?||item.status==='待验�??'#ef4444':'#0B9B96';

  var headerGrad = isTopic ? 'linear-gradient(135deg,rgba(139,92,246,0.12),rgba(99,102,241,0.08))' : 'linear-gradient(135deg,rgba(239,68,68,0.08),rgba(220,38,38,0.04))';

  var headerTextColor = isTopic ? '#6d28d9' : '#b91c1c';

  var headerBorder = isTopic ? '#ede9fe' : '#fee2e2';

  var html = ''

    +'<div class="modal-dialog" style="max-width:680px;padding:0;border-radius:16px;overflow:hidden;background:#fff;">'

      +'<div style="background:'+headerGrad+';color:'+headerTextColor+';padding:14px 20px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid '+headerBorder+';">'

        +'<div>'

          +'<div style="font-size:15px;font-weight:600;">'+(isTopic?'💡 课�?详情':'⚠️ �??详情')+'</div>'

          +'<div style="font-size:11px;opacity:0.7;">'+(isTopic?'T':'I')+String(item.id).padStart(3,'0')+' · '+item.projectName+'</div>'

        +'</div>'

        +'<button onclick="closeComparePanel()" style="background:rgba(0,0,0,0.06);border:none;color:'+headerTextColor+';width:28px;height:28px;border-radius:50%;cursor:pointer;font-size:16px;">�?/button>'

      +'</div>'

      +'<div style="padding:20px;">'

        +'<div style="display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap;">'

          +'<div style="flex:1;min-width:120px;padding:10px;background:#f8fafc;border-radius:10px;">'

            +'<div style="font-size:10px;color:#94a3b8;">状�??/div><div style="font-weight:600;color:'+statusColor+';">'+item.status+'</div></div>'

          +'<div style="flex:1;min-width:120px;padding:10px;background:#f8fafc;border-radius:10px;">'

            +'<div style="font-size:10px;color:#94a3b8;">类型</div><div style="font-weight:600;">'+item.type+'</div></div>'

          +'<div style="flex:1;min-width:120px;padding:10px;background:#f8fafc;border-radius:10px;">'

            +'<div style="font-size:10px;color:#94a3b8;">责任�?/div><div style="font-weight:600;">'+(item.assignee||'--')+'</div></div>'

          +(isTopic?'':'<div style="flex:1;min-width:120px;padding:10px;background:#f8fafc;border-radius:10px;">'

            +'<div style="font-size:10px;color:#94a3b8;">优先�?/div><div style="font-weight:600;">'+(item.priority||'--')+'</div></div>')

        +'</div>'

        +'<div style="margin-bottom:14px;"><div style="font-size:12px;font-weight:600;color:#1e40af;margin-bottom:4px;">'+'描述'+'</div><div style="font-size:13px;color:#334155;line-height:1.6;">'+(item.desc||'--')+'</div></div>'

        +(item.background?'<div style="margin-bottom:14px;"><div style="font-size:12px;font-weight:600;color:#1e40af;margin-bottom:4px;">背景</div><div style="font-size:12px;color:#475569;line-height:1.6;">'+item.background+'</div></div>':'')

        +(item.rootCause?'<div style="margin-bottom:14px;"><div style="font-size:12px;font-weight:600;color:#ef4444;margin-bottom:4px;">根因分析</div><div style="font-size:12px;color:#475569;line-height:1.6;">'+item.rootCause+'</div></div>':'')

        +(item.solution?'<div style="margin-bottom:14px;"><div style="font-size:12px;font-weight:600;color:#10b981;margin-bottom:4px;">'+(isTopic?'成果':'解决方�?')+'</div><div style="font-size:12px;color:#475569;line-height:1.6;">'+item.solution+'</div></div>':'')

        +(item.milestone?'<div style="margin-bottom:14px;"><div style="font-size:12px;font-weight:600;color:#0B9B96;margin-bottom:4px;">关键节点</div><div style="font-size:12px;color:#475569;line-height:1.6;">'+item.milestone+'</div></div>':'')

        +(item.outcome?'<div style="margin-bottom:14px;"><div style="font-size:12px;font-weight:600;color:#D4AF37;margin-bottom:4px;">�?终成�?/div><div style="font-size:12px;color:#475569;line-height:1.6;">'+item.outcome+'</div></div>':'')

        +(item.participants?'<div style="margin-bottom:14px;"><div style="font-size:12px;font-weight:600;color:#1e40af;margin-bottom:4px;">协同�?/div><div style="font-size:12px;color:#475569;">'+item.participants+'</div></div>':'')

        +'<div style="color:#94a3b8;font-size:10px;">来源�?+(item.source||'')+' · 创建�?+(item.createdAt||'')+'</div>'

      +'</div>'

    +'</div>';

  overlay.innerHTML = html;

  overlay.classList.remove('hidden');

  overlay.style.opacity = '1';

}



// ===== 核心知识能量�?=====



function renderKnowledge(){



  const can = canEdit();



  // 计算统�?数据

  const totalKnowledge = KNOWLEDGE.length;

  const weekNew = KNOWLEDGE.filter(k => {

    if (!k.createdAt) return false;

    const d = new Date(k.createdAt);

    const now = new Date();

    const weekAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);

    return d >= weekAgo;

  }).length;

  const totalViews = KNOWLEDGE.reduce((s, k) => s + (k.views || 0), 0);

  const totalDownloads = KNOWLEDGE.reduce((s, k) => s + (k.downloads || 0), 0);



  // 分类统�?

  const typeCounts = {};

  KNOWLEDGE.forEach(k => {

    typeCounts[k.type] = (typeCounts[k.type] || 0) + 1;

  });



  const typeOrder = ['SOP流程优化','风控应�?��?�?,'成本�?��控制','优�?话术萃取','AI提效赋能','培�?材料'];



  const top5 = [...KNOWLEDGE].sort((a, b) => (b.views || 0) - (a.views || 0)).slice(0, 5);



  const permIcon = {'�?��':'🌐','内部':'🔵','受限':'🔴'};

  const permLabel = {'�?��':'�?��','内部':'内部','受限':'受限'};



  return `



  <div class="kyp-header">

    <div class="kyp-header-left">

      <div class="kyp-title-row">

        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#185FA5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>

        <h1 class="kyp-title">核心知识能量�?/h1>

      </div>

      <p class="kyp-desc">电商客服团队专属知识�?· 沉淀经验 · 赋能团队</p>

    </div>

    ${can ? '<div class="kyp-add-btn" onclick="alert(\'添加知识功能�?发中\')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>添加知识</div>' : ''}

  </div>



  <div class="kyp-stats">

    <div class="kyp-stat-card">

      <div class="kyp-stat-icon kis-blue"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg></div>

      <div class="kyp-stat-body">

        <span class="kyp-stat-val">${totalKnowledge}</span>

        <span class="kyp-stat-lbl">知识总量</span>

      </div>

    </div>

    <div class="kyp-stat-card">

      <div class="kyp-stat-icon kis-green"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></div>

      <div class="kyp-stat-body">

        <span class="kyp-stat-val">${weekNew}<span class="kyp-badge-new">NEW</span></span>

        <span class="kyp-stat-lbl">�?��新�?</span>

      </div>

    </div>

    <div class="kyp-stat-card">

      <div class="kyp-stat-icon kis-orange"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></div>

      <div class="kyp-stat-body">

        <span class="kyp-stat-val">${totalViews.toLocaleString()}</span>

        <span class="kyp-stat-lbl">总浏览量</span>

      </div>

    </div>

    <div class="kyp-stat-card">

      <div class="kyp-stat-icon kis-red"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></div>

