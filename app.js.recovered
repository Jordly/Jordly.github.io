    </div>







    <div id="detail-tab-issue" class="detail-section" style="display:none;">



      <h4>课�?与问题列�?/h4>



      ${relatedIssues.length>0?`



        <table class="data-table">



          <thead><tr><th>编号</th><th>类别</th><th>类型</th><th>描述</th><th>状�??/th><th>责任�?/th></tr></thead>



          <tbody>



            ${relatedIssues.map(i=>{

              var isTop = i.category==='课�?';

              var prefix = isTop ? 'T' : 'I';

              return `



              <tr>



