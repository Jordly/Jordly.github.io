// ===== 系统用户管理（用户�?批�?理） =====



let notificationFilter = "all";



function renderNotifications(){

  if (!isAdmin()) {

    return `<div class="empty-state"><div class="empty-icon">&#x1F512;</div><p>仅�?理员�??�??模块</p></div>`;

  }



  const filtered = notificationFilter === "all" ? USERS : USERS.filter(u => {

    if (notificationFilter === "pending") return u.status === "待�?�?;

    if (notificationFilter === "active") return u.status === "已激�?;

    if (notificationFilter === "rejected") return u.status === "已拒�?;

    return true;

  });



  const statusBadge = {

    "已激�?: "badge-green",

    "待�?�?: "badge-yellow",

    "已拒�?: "badge-red",

    "已�?�?: "badge-gray"

  };



  const roleBadge = {

    "超级管理�?: "badge-purple",

    "管理�?: "badge-blue",

    "客服总监": "badge-orange",

    "客服经理": "badge-primary",

    "客服主�?": "badge-yellow",

    "客服组长": "badge-green",

    "项目伙伴": "badge-gray",

    "�?�?���?: "badge-gray",

    "风控伙伴": "badge-gray"

  };



  return `<div class="module-header">

    <div>

      <div class="module-title">&#x1F514; 系统用户管理</div>

      <div style="font-size:12px;color:var(--c-text-3);margin-top:4px;">管理系统用户，�?批注册申请，维护账号状�??/div>

    </div>

    <div class="module-actions">

      <button class="btn btn-sm btn-primary" onclick="showAddUser()">&#xFF0B; 新�?用户</button>

    </div>

  </div>



  <div style="display:flex;gap:8px;margin-bottom:16px;">

    <button class="btn btn-sm ${notificationFilter==='all'?'btn-primary':''}" onclick="setNotificationFilter('all')">全部(${USERS.length})</button>

    <button class="btn btn-sm ${notificationFilter==='pending'?'btn-primary':''}" style="background:var(--c-yellow-bg);color:var(--c-yellow);border-color:var(--c-yellow)" onclick="setNotificationFilter('pending')">待�?�?${USERS.filter(u=>u.status==='待�?�?).length})</button>

    <button class="btn btn-sm ${notificationFilter==='active'?'btn-primary':''}" style="background:var(--c-green-bg);color:var(--c-green);border-color:var(--c-green)" onclick="setNotificationFilter('active')">已激�?${USERS.filter(u=>u.status==='已激�?).length})</button>

    <button class="btn btn-sm ${notificationFilter==='rejected'?'btn-primary':''}" style="background:var(--c-red-bg);color:var(--c-red);border-color:var(--c-red)" onclick="setNotificationFilter('rejected')">已拒�?${USERS.filter(u=>u.status==='已拒�?).length})</button>

  </div>



  <div class="card">

    <table class="data-table">

      <thead>

        <tr>

          <th>用户</th>

          <th>用户�?/th>

          <th>角色</th>

          <th>状�??/th>

          <th>注册时间</th>

          <th>联系方式</th>

          <th>审批�?/th>

          <th>操作</th>

        </tr>

      </thead>

      <tbody>

        ${filtered.map(u => `

          <tr>

            <td><div style="display:flex;align-items:center;gap:8px;"><div style="width:32px;height:32px;border-radius:50%;background:var(--c-primary-light);color:var(--c-primary);display:flex;align-items:center;justify-content:center;font-weight:600;font-size:14px;">${u.name ? u.name.charAt(0) : '?'}</div><span style="font-weight:500;">${u.name || '�?���?}</span></div></td>

            <td>${u.username}</td>

            <td><span class="badge ${roleBadge[u.role]||'badge-gray'}">${u.role}</span></td>

            <td><span class="badge ${statusBadge[u.status]||'badge-gray'}">${u.status}</span></td>

            <td>${u.registerTime}</td>

            <td><div style="font-size:12px;color:var(--c-text-2);">${u.phone}<br/>${u.email}</div></td>

            <td>${u.approvedBy || "&#x2014;"}</td>

            <td class="actions">

              ${u.status === "待�?�? ? `

                <button class="btn btn-sm btn-primary" onclick="approveUser('${u.id}', '同意')">同意</button>

                <button class="btn btn-sm" style="background:var(--c-red-bg);color:var(--c-red);border-color:var(--c-red);" onclick="approveUser('${u.id}', '拒绝')">拒绝</button>

                <button class="btn btn-sm" onclick="approveUser('${u.id}', '忽略')">忽略</button>

              ` : `

                <button class="btn btn-sm" onclick="editUserRole('${u.id}')">改�?�?/button>

                <button class="btn btn-sm" onclick="resetUserPassword('${u.id}')">重置密码</button>

                ${u.status !== "已�?�? ? `<button class="btn btn-sm" style="background:var(--c-yellow-bg);color:var(--c-yellow);border-color:var(--c-yellow);" onclick="disableUser('${u.id}')">禁用</button>` : `<button class="btn btn-sm btn-primary" onclick="enableUser('${u.id}')">�?��</button>`}

                ${isSuperAdmin() ? `<button class="btn btn-sm" style="background:var(--c-red-bg);color:var(--c-red);border-color:var(--c-red);" onclick="deleteUser('${u.id}')">删除</button>` : ""}

              `}

            </td>

          </tr>

        `).join("")}

      </tbody>

    </table>

    ${filtered.length === 0 ? `<div style="text-align:center;padding:40px;color:var(--c-text-3);">暂无符合条件的用�?/div>` : ""}

  </div>

  `;

}



function setNotificationFilter(filter){

  notificationFilter = filter;

  renderModule("notifications");

}



function approveUser(userId, action){

  const user = USERS.find(u => u.id === userId);

  if (!user) return;

  if (action === "同意") {

    user.status = "已激�?;

    user.approvedBy = currentUser ? currentUser.name : "admin";

    // 新用户默认�?色为"新用�?，所有权限只�?    if (!user.role) user.role = "新用�?;

    saveUsers();

    alert(`已同�?${user.name} 的注册申请，账号已激活�?�`);

  } else if (action === "拒绝") {

    user.status = "已拒�?;

    user.approvedBy = currentUser ? currentUser.name : "admin";

    saveUsers();

    alert(`已拒�?${user.name} 的注册申请�?�`);

  } else if (action === "忽略") {

    alert(`已忽�?${user.name} 的注册申请，该申请仍保留在待审核列表�??�`);

    return;

  }

  renderModule("notifications");

}



function editUserRole(userId){

  const user = USERS.find(u => u.id === userId);

  if (!user) return;

  const roles = ["客服组长","客服主�?","客服经理","客服总监","管理�?,"项目伙伴","�?�?���?,"风控伙伴"];

  const roleOptions = roles.map(r => `<option value="${r}" ${r===user.role?'selected':''}>${r}</option>`).join('');



  const modalHtml = `

    <div class="modal-overlay" id="role-modal-overlay" onclick="if(event.target===this)closeRoleModal()">

      <div class="modal-box" style="max-width:320px;border-radius:10px;box-shadow:0 12px 40px rgba(0,0,0,0.15);">

        <div class="modal-header" style="padding:12px 16px;border-bottom:1px solid #f1f5f9;">

          <div style="font-size:13px;font-weight:600;color:var(--c-text);">�?��角色</div>

          <button class="modal-close" onclick="closeRoleModal()" style="font-size:18px;color:#94a3b8;">&times;</button>

        </div>

        <div class="modal-body" style="padding:16px;">

          <div style="margin-bottom:10px;font-size:12px;color:#94a3b8;">�?<strong style="color:var(--c-primary);">${user.name}</strong> 选择新�?�?/div>

          <div style="position:relative;">

            <select id="role-select-input" style="width:100%;padding:8px 28px 8px 10px;font-size:12px;color:var(--c-text);border:1px solid #e2e8f0;border-radius:6px;background:#fff;appearance:none;cursor:pointer;outline:none;transition:border-color 0.2s;">

              ${roleOptions}

            </select>

            <div style="position:absolute;right:10px;top:50%;transform:translateY(-50%);pointer-events:none;font-size:10px;color:#94a3b8;">�?/div>

          </div>

        </div>

        <div class="modal-footer" style="padding:10px 16px 14px;gap:8px;">

          <button class="btn" onclick="closeRoleModal()" style="padding:6px 14px;font-size:12px;border-radius:6px;background:#f8fafc;color:#64748b;border:1px solid #e2e8f0;">取消</button>

          <button class="btn btn-primary" onclick="confirmEditRole('${userId}')" style="padding:6px 14px;font-size:12px;border-radius:6px;">�?��</button>

        </div>

      </div>

    </div>`;



  document.body.insertAdjacentHTML('beforeend', modalHtml);

}



function closeRoleModal(){

  const el = document.getElementById('role-modal-overlay');

  if(el) el.remove();

}



function confirmEditRole(userId){

  const user = USERS.find(u => u.id === userId);

  const sel = document.getElementById('role-select-input');

  if(!user || !sel) return;

  const newRole = sel.value;

  if(newRole && newRole !== user.role){

    user.role = newRole;

    saveUsers();

    alert(`已修�?${user.name} 的�?色为�?{newRole}`);

    renderModule("notifications");

  }

  closeRoleModal();

}



function resetUserPassword(userId){

  const user = USERS.find(u => u.id === userId);

  if (!user) return;

  const newPwd = prompt(`重置 ${user.name} 的密码：\n请输入新密码（至�?位）：`);

  if (newPwd && newPwd.length >= 6) {

    user.password = newPwd;

    alert(`已重�?${user.name} 的密码�?�`);

  } else if (newPwd) {

    alert("密码长度不足6�?);

  }

}



function disableUser(userId){

  const user = USERS.find(u => u.id === userId);

  if (!user) return;

  if (user.role === "超级管理�?) { alert("不能禁用超级管理�?); return; }

  if (confirm(`�?��要�?用用�?${user.name} 吗？`)) {

    user.status = "已�?�?;

    saveUsers();

    renderModule("notifications");

  }

}



function enableUser(userId){

  const user = USERS.find(u => u.id === userId);

  if (!user) return;

  user.status = "已激�?;

  saveUsers();

  renderModule("notifications");

}



function deleteUser(userId){

  const user = USERS.find(u => u.id === userId);

  if (!user) return;

  if (user.role === "超级管理�?) { alert("不能删除超级管理�?); return; }

  if (confirm(`�?��要删除用�?${user.name} 吗？此操作不�?��复�?�`)) {

    const idx = USERS.findIndex(u => u.id === userId);

    if (idx > -1) USERS.splice(idx, 1);

    saveUsers();

    renderModule("notifications");

  }

}



function showAddUser(){

  if (!isAdmin()) { alert("仅�?理员�?��增用�?); return; }

  const name = prompt("用户姓名�?);

  if (!name) return;

  const username = prompt("登录账号�?);

  if (!username || USERS.some(u => u.username === username)) { alert("账号为空或已存在"); return; }

  const password = prompt("初�?密码�?);

  if (!password) return;

  const role = prompt("角色（�?服组�?客服主�?/客服经理/客服总监/管理员）�?) || "客服组长";

  const newUser = {

    id: "U" + String(USERS.length + 1).padStart(3, "0"),

    name, username, password, role,

    status: "已激�?, registerTime: new Date().toISOString().slice(0, 10),

    phone: "", email: "", approvedBy: currentUser ? currentUser.name : "admin", remark: ""

  };

  USERS.push(newUser);

  renderModule("notifications");

}



// ===== 系统权限管理（新版） =====



function renderPermissions(){

  // 防御性�?�?  if (typeof ROLES === "undefined" || !ROLES || !ROLES.length) {

    document.getElementById("module-content").innerHTML = '<div style="padding:40px;text-align:center;color:red;">错�?：�?色列表未加载</div>';

    return;

  }

  

  // �?��rolePermissions有数�?  if (!rolePermissions || Object.keys(rolePermissions).length === 0) {

    rolePermissions = JSON.parse(JSON.stringify(DEFAULT_PERMISSIONS || {}));

  }

  

  var selRole = window._selectedPermRole || ROLES[0] || '';

  var rp = rolePermissions[selRole] || {};

  var groupOrder = ['project','collab','tools','system'];

  

  // 构建右侧模块卡片

  var cardsHtml = '';

  for(var gi=0; gi<groupOrder.length; gi++){

    var g = MODULE_GROUPS[groupOrder[gi]];

    if(!g || !g.keys) continue;

    var modCards = '';

    for(var mi=0; mi<g.keys.length; mi++){

      var mk = g.keys[mi];

      var ma = MODULE_ACTIONS[mk] || {};

      var mp = rp[mk] || {visible:false,view:false,edit:false,import:false,export:false,manage:false,scope:'all'};

      

      // 兼�?旧格�?      if(typeof mp==='string'){

        if(mp==='write') mp={visible:true,view:true,edit:true,import:false,export:true,manage:false,scope:'all'};

        else if(mp==='read') mp={visible:true,view:true,edit:false,import:false,export:true,manage:false,scope:'all'};

        else mp={visible:false,view:false,edit:false,import:false,export:false,manage:false,scope:'all'};

      }

      

      var actionsHtml = '';

      var actionDefs = [

        {key:'visible', label:'�??', icon:'👁'},

        {key:'view', label:'查看', icon:'📖'},

        {key:'edit', label:'编辑', icon:'✏️'},

        {key:'import', label:'导入', icon:'📥'},

        {key:'export', label:'导出', icon:'📤'},

        {key:'manage', label:'管理', icon:'⚙️'}

      ];

      for(var ai=0; ai<actionDefs.length; ai++){

        var a = actionDefs[ai];

        if(ma[a.key] !== 1){

          actionsHtml += '<span style="display:inline-block;padding:3px 8px;margin-right:6px;border-radius:6px;font-size:11px;color:#cbd5e1;background:#f8fafc;border:1px solid #f1f5f9;">'+a.icon+' '+a.label+'</span>';

        } else {

          var checked = mp[a.key]===true;

          actionsHtml += '<label style="display:inline-block;padding:3px 8px;margin-right:6px;cursor:pointer;border-radius:6px;font-size:11px;transition:all 0.15s;'

            +(checked?'color:#0f766e;background:rgba(11,155,150,0.08);border:1px solid rgba(11,155,150,0.2);':'color:#94a3b8;background:#fff;border:1px solid #e2e8f0;')

            +'"><input type="checkbox" onchange="togglePermAction(\''+selRole+'\',\''+mk+'\',\''+a.key+'\',this.checked)" '+(checked?'checked':'')+' style="display:none;">'+a.icon+' '+a.label+'</label>';

        }

      }

      

      // 数据范围

      var scopeHtml = '';

      if(ma.scope===1){

        var isAll = mp.scope==='all';

        scopeHtml = '<span style="margin-left:8px;font-size:10px;color:#94a3b8;">数据:</span>'

          +'<label style="margin-left:4px;cursor:pointer;font-size:11px;color:'+(isAll?'#0f766e':'#94a3b8')+';" onclick="togglePermScope(\''+selRole+'\',\''+mk+'\',\'all\')">全部项目</label>'

          +'<label style="margin-left:6px;cursor:pointer;font-size:11px;color:'+(!isAll?'#0f766e':'#94a3b8')+';" onclick="togglePermScope(\''+selRole+'\',\''+mk+'\',\'own\')">仅自己项�?/label>';

      }

      

      modCards += '<div style="padding:10px 14px;border-bottom:1px solid #f1f5f9;display:flex;align-items:center;flex-wrap:wrap;gap:6px;">'

        +'<div style="width:110px;flex-shrink:0;font-size:12px;font-weight:500;color:#334155;">'+(MODULE_NAMES[mk]||mk)+'</div>'

        +'<div style="flex:1;min-width:280px;">'+actionsHtml+'</div>'

        +'<div style="flex-shrink:0;">'+scopeHtml+'</div></div>';

    }

    cardsHtml += '<div style="margin-bottom:14px;"><div style="font-size:13px;font-weight:600;color:#1e40af;margin-bottom:8px;padding-left:4px;">'+(g.label||'')+'</div>'

      +'<div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;">'+modCards+'</div></div>';

  }

  

  // 保存状�??  var saveStatus = window._permSaveStatus || '';

  var saveHint = (saveStatus && saveStatus !== 'undefined' && saveStatus !== 'null') 

    ? '<span style="font-size:11px;color:'+(saveStatus==='saved'?'#10b981':'#ef4444')+';margin-left:8px;">'+(saveStatus==='saved'?'�?已保�?:'⚠️ '+saveStatus)+'</span>' 

    : '';

  

  // 角色列表HTML

  var roleListHtml = '';

  for(var ri=0; ri<ROLES.length; ri++){

    var r = ROLES[ri];

    if(!r) continue;

    var isSel = r===selRole;

    roleListHtml += '<div onclick="selectPermRole(\''+r+'\')" style="cursor:pointer;padding:10px 14px;margin-bottom:4px;border-radius:8px;font-size:13px;font-weight:500;transition:all 0.15s;'

      +(isSel?'background:rgba(11,155,150,0.08);color:#0f766e;border-left:3px solid #0B9B96;':'background:#fff;color:#475569;border-left:3px solid transparent;')+'">'+r+'</div>';

  }

  

  var html = ''

    +'<div class="module-header"><div><div class="module-title">⚙️ 系统权限管理</div>'

    +'<div style="font-size:12px;color:#94a3b8;margin-top:4px;">�?�??色配�?��功能模块的�?�?��操作权限</div></div>'

    +'<div class="module-actions"><button class="btn btn-sm" onclick="exportPerms()">📤 导出配置</button>'

    +'<button class="btn btn-sm" onclick="resetAllPerms()">🔄 恢�?默�?</button>'+saveHint+'</div></div>'

    +'<div style="display:flex;gap:16px;"><div style="width:140px;flex-shrink:0;">'

    +'<div style="font-size:11px;color:#94a3b8;margin-bottom:8px;padding-left:12px;">角色 ('+(ROLES&&ROLES.length?ROLES.length:0)+')</div>'

    +roleListHtml

    +'</div><div style="flex:1;min-width:0;">'

    +'<div style="font-size:11px;color:#94a3b8;margin-bottom:8px;">权限配置 �?'+selRole+'</div>'

    +cardsHtml

    +'<div style="margin-top:12px;display:flex;gap:8px;"><button class="btn btn-sm" onclick="resetRolePerm(\''+selRole+'\')">🔄 恢�?此�?色默�?/button>'

    +'<span style="font-size:11px;color:#94a3b8;align-self:center;">�?��后自动保存到�?��</span></div></div></div>';

  

  document.getElementById("module-content").innerHTML = html;

}

  if (!rolePermissions || Object.keys(rolePermissions).length === 0) {

    var dp = (typeof DEFAULT_PERMISSIONS !== 'undefined' && DEFAULT_PERMISSIONS) ? DEFAULT_PERMISSIONS : {};

    rolePermissions = (dp && Object.keys(dp).length > 0) ? JSON.parse(JSON.stringify(dp)) : {};

    try { localStorage.setItem("chansee_permissions", JSON.stringify(rolePermissions)); } catch(e){}

  }

  var selRole = window._selectedPermRole || ROLES[0];

  var rp = rolePermissions[selRole] || {};

  var groupOrder = ['project','collab','tools','system'];

  var cardsHtml = '';

  for(var gi=0; gi<groupOrder.length; gi++){

    var g = MODULE_GROUPS[groupOrder[gi]];

    if(!g) continue;

    var modCards = '';

    for(var mi=0; mi<g.keys.length; mi++){

      var mk = g.keys[mi];

      var ma = MODULE_ACTIONS[mk] || {};

      var mp = rp[mk];

      if(typeof mp==='string'){

        if(mp==='write') mp={visible:true,view:true,edit:true,import:false,export:true,manage:false,scope:'all'};

        else if(mp==='read') mp={visible:true,view:true,edit:false,import:false,export:true,manage:false,scope:'all'};

        else mp={visible:false,view:false,edit:false,import:false,export:false,manage:false,scope:'all'};

      }

      if(!mp||typeof mp!=='object') mp={visible:false,view:false,edit:false,import:false,export:false,manage:false,scope:'all'};

      var actionsHtml = '';

      var actionDefs = [

        {key:'visible', label:'�??', icon:'👁'},

        {key:'view', label:'查看', icon:'📖'},

        {key:'edit', label:'编辑', icon:'✏️'},

        {key:'import', label:'导入', icon:'📥'},

        {key:'export', label:'导出', icon:'📤'},

        {key:'manage', label:'管理', icon:'⚙️'}

      ];

      for(var ai=0; ai<actionDefs.length; ai++){

        var a = actionDefs[ai];

        if(ma[a.key] !== 1){

          actionsHtml += '<span style="display:inline-block;padding:3px 8px;margin-right:6px;border-radius:6px;font-size:11px;color:#cbd5e1;background:#f8fafc;border:1px solid #f1f5f9;">'+a.icon+' '+a.label+'</span>';

        } else {

          var checked = mp[a.key]===true;

          actionsHtml += '<label style="display:inline-block;padding:3px 8px;margin-right:6px;cursor:pointer;border-radius:6px;font-size:11px;transition:all 0.15s;'

            +(checked?'color:#0f766e;background:rgba(11,155,150,0.08);border:1px solid rgba(11,155,150,0.2);':'color:#94a3b8;background:#fff;border:1px solid #e2e8f0;')

            +'"><input type="checkbox" onchange="togglePermAction(\''+selRole+'\',\''+mk+'\',\''+a.key+'\',this.checked)" '+(checked?'checked':'')+' style="display:none;">'+a.icon+' '+a.label+'</label>';

        }

      }

      var scopeHtml = '';

      if(ma.scope===1){

        var isAll = mp.scope==='all';

        scopeHtml = '<span style="margin-left:8px;font-size:10px;color:#94a3b8;">数据:</span>'

          +'<label style="margin-left:4px;cursor:pointer;font-size:11px;color:'+(isAll?'#0f766e':'#94a3b8')+';" onclick="togglePermScope(\''+selRole+'\',\''+mk+'\',\'all\')">全部项目</label>'

          +'<label style="margin-left:6px;cursor:pointer;font-size:11px;color:'+(!isAll?'#0f766e':'#94a3b8')+';" onclick="togglePermScope(\''+selRole+'\',\''+mk+'\',\'own\')">仅自己项�?/label>';

      }

      modCards += '<div style="padding:10px 14px;border-bottom:1px solid #f1f5f9;display:flex;align-items:center;flex-wrap:wrap;gap:6px;" class="perm-mod-row">'

        +'<div style="width:110px;flex-shrink:0;font-size:12px;font-weight:500;color:#334155;">'+(MODULE_NAMES[mk]||mk)+'</div>'

        +'<div style="flex:1;min-width:280px;">'+actionsHtml+'</div>'

        +'<div style="flex-shrink:0;">'+scopeHtml+'</div></div>';

    }

    cardsHtml += '<div style="margin-bottom:14px;"><div style="font-size:13px;font-weight:600;color:#1e40af;margin-bottom:8px;padding-left:4px;">'+g.label+'</div>'

      +'<div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;">'+modCards+'</div></div>';

  }

  var saveStatus = window._permSaveStatus || '';

  var saveHint = '';

  if(saveStatus && saveStatus !== 'undefined' && saveStatus !== 'null'){

    saveHint = '<span style="font-size:11px;color:'+(saveStatus==='saved'?'#10b981':'#ef4444')+';margin-left:8px;">'+(saveStatus==='saved'?'�?已保�?:'⚠️ '+saveStatus)+'</span>';

  }

  var html = ''

    +'<div class="module-header"><div><div class="module-title">⚙️ 系统权限管理</div>'

    +'<div style="font-size:12px;color:#94a3b8;margin-top:4px;">�?�??色配�?��功能模块的�?�?��操作权限</div></div>'

    +'<div class="module-actions"><button class="btn btn-sm" onclick="exportPerms()">📤 导出配置</button>'

    +'<button class="btn btn-sm" onclick="resetAllPerms()">🔄 恢�?默�?</button>'+saveHint+'</div></div>'

    +'<div style="display:flex;gap:16px;"><div style="width:140px;flex-shrink:0;">'

    +'<div style="font-size:11px;color:#94a3b8;margin-bottom:8px;padding-left:12px;">角色 ('+(ROLES&&ROLES.length?ROLES.length:0)+')</div>'

    +(ROLES||[]).map(function(r){

      if(!r) return '';

      var isSel=r===selRole; return '<div onclick="selectPermRole(\''+r+'\')" style="cursor:pointer;padding:10px 14px;margin-bottom:4px;border-radius:8px;font-size:13px;font-weight:500;transition:all 0.15s;'

      +(isSel?'background:rgba(11,155,150,0.08);color:#0f766e;border-left:3px solid #0B9B96;':'background:#fff;color:#475569;border-left:3px solid transparent;')+'">'+r+'</div>';}).join('')

    +'</div><div style="flex:1;min-width:0;">'

    +'<div style="font-size:11px;color:#94a3b8;margin-bottom:8px;">权限配置 �?'+selRole+'</div>'

    +cardsHtml

    +'<div style="margin-top:12px;display:flex;gap:8px;"><button class="btn btn-sm" onclick="resetRolePerm(\''+selRole+'\')">🔄 恢�?此�?色默�?/button>'

    +'<span style="font-size:11px;color:#94a3b8;align-self:center;">�?��后自动保存到�?��</span></div></div></div>';

  document.getElementById("module-content").innerHTML = html;

}



function selectPermRole(role){ window._selectedPermRole = role; renderModule('permissions'); }

function togglePermAction(role, module, action, checked){

  if(!rolePermissions[role]) rolePermissions[role] = {};

  if(!rolePermissions[role][module] || typeof rolePermissions[role][module] === 'string')

    rolePermissions[role][module] = { visible:true, view:true, edit:false, import:false, export:false, manage:false, scope:'all' };

  rolePermissions[role][module][action] = checked;

  saveRolePermissions(); window._permSaveStatus = 'saved'; renderModule('permissions');

}

function togglePermScope(role, module, scope){

  if(!rolePermissions[role]) rolePermissions[role] = {};

  if(!rolePermissions[role][module] || typeof rolePermissions[role][module] === 'string')

    rolePermissions[role][module] = { visible:true, view:true, edit:false, import:false, export:false, manage:false, scope:'all' };

  rolePermissions[role][module].scope = scope;

  saveRolePermissions(); window._permSaveStatus = 'saved'; renderModule('permissions');

}

function saveRolePermissions(){ try { localStorage.setItem('chansee_permissions', JSON.stringify(rolePermissions)); } catch(e) { window._permSaveStatus = '保存失败'; } }

function resetRolePerm(role){ if(!confirm('�?��恢�?�?+role+'」的默�?权限配置吗？')) return; rolePermissions[role] = JSON.parse(JSON.stringify(DEFAULT_PERMISSIONS[role] || {})); saveRolePermissions(); window._permSaveStatus = 'saved'; renderModule('permissions'); }

function resetAllPerms(){ if(!confirm('�?��恢�?�?有�?色的默�?权限配置吗？此操作不�?���?�?)) return; rolePermissions = JSON.parse(JSON.stringify(DEFAULT_PERMISSIONS)); saveRolePermissions(); window._permSaveStatus = 'saved'; renderModule('permissions'); }

function exportPerms(){ var blob = new Blob(['\uFEFF'+JSON.stringify(rolePermissions, null, 2)], {type:'application/json;charset=utf-8'}); var a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = '权限配置_'+new Date().toISOString().slice(0,10)+'.json'; a.click(); }



// 旧函数兼容（保留但不再使�?��

function renderPermissions_OLD(){

  // 防御性�?�?  if (typeof ROLES === "undefined") {

    document.getElementById("module-content").innerHTML = '<div style="padding:40px;text-align:center;color:red;">错�?：ROLES �?���?/div>';

    return;

  }

  if (typeof rolePermissions === "undefined") {

    rolePermissions = {};

  }



  const allModules = [

          const perms = rolePermissions[role] || {};

          const writeCount = allModules.filter(m => perms[m.key]==="write").length;

          const readCount = allModules.filter(m => perms[m.key]==="read").length;

          const hiddenCount = allModules.filter(m => perms[m.key]==="hidden" || !perms[m.key]).length;

          return `

            <div class="card" style="padding:10px 14px;">

              <div style="font-weight:500;font-size:13px;margin-bottom:6px;">${role}</div>

              <div style="display:flex;gap:8px;font-size:11px;">

                <span style="color:#16a34a;">读写${writeCount}</span>

                <span style="color:#2563eb;">�??${readCount}</span>

                <span style="color:#9ca3af;">隐藏${hiddenCount}</span>

              </div>

            </div>`;

        }).join('')}

      </div>

    </div>



    <div class="card" style="margin-top:16px;padding:14px 18px;">

      <div style="font-size:13px;font-weight:500;margin-bottom:8px;">📋 权限说明</div>

      <ul style="font-size:12px;color:var(--c-text-2);line-height:1.8;">

        <li><b style="color:#16a34a;">读写</b>：可以查看和编辑该模块的�?有内�?/li>

        <li><b style="color:#2563eb;">�??</b>：只能查看�?模块的内容，不能编辑</li>

        <li><b style="color:#9ca3af;">隐藏</b>：�?模块对�?角色不可见，左侧导航栏不显示</li>

        <li>权限配置�?��保存到浏览器�?��存储，清除浏览器数据会重�?��默�?</li>

      </ul>

    </div>`;



  // 不再直接操作 innerHTML，改为返�?html 字�?串（与其他渲染函数一致）

  return html;

}



// ===== 项目难度评估（优化版�?====

// 计算管理基准分（根据管理等级�?function getManagementBenchmark(level) {

  if (!level) return 35;

  if (level.includes('组长-1')) return 35;

  if (level.includes('组长-2')) return 45;

  if (level.includes('组长-3')) return 55;

  if (level.includes('主�?')) return 70;

  if (level.includes('经理')) return 90;

  if (level.includes('培�?�?)) return 30;

  return 35;

}



// 计算适配度（百分比）

function calcCompatibility(projectScore, managementBenchmark) {

  const diff = Math.abs(projectScore - managementBenchmark);

  const compatibility = Math.max(0, Math.min(100, 100 - diff * 1.25));

  return Math.round(compatibility);

}



// 获取适配度档�?function getCompatibilityBand(pct) {

  if (pct < 60) return { label: '<60% 不匹�?, color: '#f5222d', bg: '#fff1f0' };

  if (pct < 80) return { label: '60%-80% 基本匹配', color: '#fa8c16', bg: '#fff7e6' };

  return { label: '80%-100% 高度匹配', color: '#52c41a', bg: '#f6ffed' };

}



// 获取难度等级

function getDifficultyLevel(score) {

  if (score <= 40) return { label: '低难�?, color: '#52c41a', cls: 'low' };

  if (score <= 50) return { label: '�?��难度', color: '#1890ff', cls: 'mid-low' };

  if (score <= 60) return { label: '�?��难度', color: '#faad14', cls: 'mid-high' };

  if (score <= 80) return { label: '高难�?, color: '#fa8c16', cls: 'high' };

  return { label: '超高难度', color: '#f5222d', cls: 'extreme' };

}



// 渲染项目难度评估页面（优化版�?function renderAssessment(){

  // 数据准�?

  let groups = GROUPS_DATA.filter(g => g.month === '7�? && g.group && !g.group.includes('定量指标'));

  let assessments = ASSESSMENTS_DATA.filter(a => a.month === '7�? && a.group && !a.month.includes('依据'));

  const deptFilter = document.getElementById('asmt-dept-filter') ? document.getElementById('asmt-dept-filter').value : '';

  const mgrFilter = document.getElementById('asmt-mgr-filter') ? document.getElementById('asmt-mgr-filter').value : '';

  if (deptFilter) assessments = assessments.filter(a => a.dept === deptFilter);

  if (mgrFilter) assessments = assessments.filter(a => a.manager === mgrFilter);



  // 统�?卡片数据

  let highDiff = 0, midDiff = 0, lowDiff = 0;

  let highMgr = 0, midMgr = 0, lowMgr = 0;

  let totalCompat = 0, compatCount = 0;

  assessments.forEach(a => {

    const score = a.totalScore || 0;

    const bench = getManagementBenchmark(a.level);

    const compat = calcCompatibility(score, bench);

    totalCompat += compat;

    compatCount++;

    const dl = getDifficultyLevel(score);

    if (dl.cls === 'high' || dl.cls === 'extreme') highDiff++;

    else if (dl.cls === 'mid-high' || dl.cls === 'mid-low') midDiff++;

    else lowDiff++;

    if (bench >= 70) highMgr++;

    else if (bench >= 50) midMgr++;

    else lowMgr++;

  });

  const avgCompat = compatCount > 0 ? Math.round(totalCompat / compatCount) : 0;

  const compatBand = getCompatibilityBand(avgCompat);



  // ===== �?始渲�?=====

  let html = `<div class="page-header"><h2>📊 项目难度评估</h2>

    <div class="page-actions">

      <button class="btn btn-sm" onclick="importAssessment()">📥 导入</button>

      <button class="btn btn-sm" onclick="exportAssessment()">📤 导出</button>

      <button class="btn btn-sm btn-primary" onclick="showCompareModal()">🔄 �?��对比</button>

    </div>

  </div>`;

  html += `<div style="margin:12px 0 8px;color:#888;font-size:13px;">数据来源：组�?���?信息 + 管理难度评估�?��2026�?月）</div>`;



  // 筛�?�栏（使用系统统�?�?filter-bar-v4 规范�?  html += `<div class="filter-bar-v4">`;

  html += `<div class="filter-row-v4">`;

  html += `  <div style="display:flex;align-items:center;gap:6px;">`;

  html += `    <span style="font-size:13px;color:var(--c-text-2);white-space:nowrap;">筛�?�项�?/span>`;

  html += `    <select id="asmt-dept-filter" class="fb-select">`;

  html += `      <option value="">全部</option>`;

  [...new Set(assessments.map(a => a.dept))].filter(Boolean).forEach(d => {

    html += `      <option value="${d}">${d}</option>`;

  });

  html += `    </select>`;

  html += `  </div>`;

  html += `  <div style="display:flex;align-items:center;gap:6px;">`;

  html += `    <span style="font-size:13px;color:var(--c-text-2);white-space:nowrap;">筛�?��?理人</span>`;

  html += `    <select id="asmt-mgr-filter" class="fb-select">`;

  html += `      <option value="">全部</option>`;

  assessments.map(a => a.manager).filter((v,i, a) => v && a.indexOf(v) === i).forEach(m => {

    html += `      <option value="${m}">${m}</option>`;

  });

  html += `    </select>`;

  html += `  </div>`;

  html += `  <div style="margin-left:auto;display:flex;gap:8px;align-items:center;">`;

  html += `    <button class="btn btn-sm btn-primary" onclick="renderAssessment()">🔍 �?��</button>`;

  html += `  </div>`;

  html += `</div></div>`;



  // ===== 卡片�?=====

  html += `<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px;">`;

  // 卡片1：高难度项目

  html += `  <div class="stat-card" style="background:#fff1f0;border:1px solid #ffa39e;border-radius:10px;padding:16px;">`;

