      </div>

      <div style="text-align:center;margin-bottom:12px;">

        ${(function(){

          // 动�?�生成饼图SVG�?��

          var r = 52;

          var totalPct = staffConfig.length ? staffConfig.reduce(function(s,sc){return s+(sc.pct||0);},0) : 0;

          if(totalPct === 0) totalPct = 1;

          var startAngle = -Math.PI/2; // 从顶部开�?          var piePaths = '';

          for(var si=0; si<staffConfig.length; si++){

            var segPct = staffConfig[si].pct || 0;

            var segAngle = (segPct / totalPct) * Math.PI * 2;

            var endAngle = startAngle + segAngle;

            var x1 = Math.round(r * Math.cos(startAngle));

            var y1 = Math.round(r * Math.sin(startAngle));

            var x2 = Math.round(r * Math.cos(endAngle));

            var y2 = Math.round(r * Math.sin(endAngle));

            var largeArc = segAngle > Math.PI ? 1 : 0;

            piePaths += '<path d="M 0,0 L '+x1+','+y1+' A '+r+','+r+' 0 '+largeArc+',1 '+x2+','+y2+' Z" fill="'+(staffConfig[si].color||'#0B9B96')+'" stroke="#fff" stroke-width="2"/>';

            startAngle = endAngle;

          }

          return '<svg width="140" height="140" viewBox="-70 -70 140 140"><defs><filter id="pieShadow2" x="-20%" y="-20%" width="140%" height="140%"><feDropShadow dx="0" dy="2" stdDeviation="3" flood-color="#000" flood-opacity="0.12"/></filter></defs><g filter="url(#pieShadow2)">'+piePaths+'</g><circle cx="0" cy="0" r="22" fill="#fff"/><text x="0" y="-2" text-anchor="middle" font-size="11" font-weight="700" fill="#312e81">'+totalStaff+'</text><text x="0" y="11" text-anchor="middle" font-size="8" fill="#64748b">总人�?/text></svg>';

        })()}

