          +'<td>'+i.projectName+'</td>'

          +'<td><span style="display:inline-block;padding:2px 10px;border-radius:12px;font-size:11px;font-weight:600;color:'+ttc+';background:'+tc+';">'+i.type+'</span></td>'

          +'<td style="font-size:12px;color:#475569;">'+i.desc+'</td>'

