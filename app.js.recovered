          } catch(e) {

          }

        } else {

        }

      } catch(e) {

      }

    } else {

    }

    if (raw) {

      const data = JSON.parse(raw);

      // 校验�?��过期

      if (data._expiry && Date.now() > data._expiry) {

        sessionStorage.removeItem("chansee_current_user");

        localStorage.removeItem("chansee_current_user");

        throw new Error("session expired");

      }

      // �?session 里的 id �?USERS 数组取最新完整数�?      const userInDb = USERS.find(u => u.id === data.id);

      if (userInDb) {

        // 构�??currentUser（不�?��码）

        // 注意：以 USERS 数组（云�?��新数�?��为准，不再用旧的 session 数据覆盖

        currentUser = {};

