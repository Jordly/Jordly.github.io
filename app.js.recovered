    </div>



    <div class="kyp-sidebar">

      <div class="kyp-sb-section">

        <div class="kyp-sb-title">🔥 �?��排�?�?TOP5</div>

        ${top5.map((k, i) => `

          <div class="kyp-rank-item" onclick="showKnowledgeDetail(${k.id})">

