  if (!confirm("⚠️ �?��要�?�?团队吗？离开后您将无法查看�?团队的任何�?录！")) return;

  if (!confirm("再�?�??：您真的要�?�?团队吗？此操作不�?���?�?)) return;

  const btn = document.querySelector(".profile-btn-danger");

  if (btn) { btn.classList.add("btn-loading"); btn.disabled = true; btn.textContent = "处理�?; }

  const userInDb = USERS.find(u => currentUser && u.id === currentUser.id);

  if (userInDb) {

    userInDb.status = "已�?�?;

    userInDb.remark = "用户主动离开团队";

  }

  showToast("您已离开团队");

  setTimeout(() => logout(), 800);

}



function exportRisk(){

  const headers = ['项目编号','预�?类型','风险等级','�??描述','发现日期','负责�?,'状�??,'解决日期'];

  const rows = RISK_ALERTS.map(r => [

    r.projectId, r.type||'', r.level||'', r.description||'',

