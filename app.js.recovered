                      // �?查云�?���?��否缺少名称字段（同时�?�?name �?nickname�?                      var cloudHasName = USERS[ui].name && USERS[ui].name !== '系统创建�? && USERS[ui].name !== '�??�? && USERS[ui].name !== '';

                      var cloudHasNickname = USERS[ui].nickname && USERS[ui].nickname !== '系统创建�? && USERS[ui].nickname !== '�??�?;

                      if (!cloudHasName && !cloudHasNickname) {

                        // 云�?没有正确的名�?�?用本地的补全（优先用 name�?                        if (bu.name && bu.name !== '系统创建�? && bu.name !== '�??�?) {

                          USERS[ui].name = bu.name;

