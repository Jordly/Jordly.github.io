  } else {

    // �??视图

    var allStatusBtns = [['all','全部('+filtered.length+')'],['待�?�?,'待�?�?'+filtered.filter(function(i){return i.status==='待�?�?;}).length+')'],['处理�?,'处理�?'+filtered.filter(function(i){return i.status==='处理�?;}).length+')'],['待验�?,'待验�?'+filtered.filter(function(i){return i.status==='待验�?;}).length+')'],['已关�?,'已关�?'+filtered.filter(function(i){return i.status==='已关�?;}).length+')']];

    var statusBtns = allStatusBtns.map(function(s){

      return '<span class="issue-filter-btn'+(issueFilterState.status===s[0]?' issue-filter-active':'')+'" onclick="filterIssueByStatus(\''+s[0]+'\',this)">'+s[1]+'</span>';

    }).join('');



    tableHtml = '<table class="issue-table"><thead><tr>'

      +'<th style="width:8%;">状�??/th><th style="width:9%;">编号</th><th style="width:11%;">项目</th><th style="width:8%;">类型</th>'

      +'<th style="width:25%;">�??描述</th><th style="width:7%;text-align:center;">优先�?/th><th style="width:7%;">责任�?/th><th style="width:7%;">归属</th><th style="width:18%;text-align:center;">操作</th></tr></thead><tbody>'

      +filtered.map(function(i){

        var rowClass = (i.status==='待�?�?||i.priority==='紧�??)?'issue-row-danger':i.status==='待验�??'issue-row-danger':i.status==='处理�??'issue-row-warning':'';

        var sc=''; if(i.status==='已关�?) sc='issue-badge-success'; else if(i.status==='待�?�?) sc='issue-badge-danger'; else if(i.status==='待验�?) sc='issue-badge-warning'; else sc='issue-badge-info';

        var pc=''; if(i.priority==='紧�??) pc='issue-priority-danger'; else if(i.priority==='重�?') pc='issue-priority-warning'; else pc='issue-priority-gray';

        return '<tr class="'+rowClass+'">'

