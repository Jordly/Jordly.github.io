    data: HANDOVERS,
    fields: [
      {key:'id', label:'ID', type:'text', required:true},
      {key:'projectId', label:'椤圭洰ID', type:'text'},
      {key:'projectName', label:'椤圭洰鍚嶇О', type:'text'},
      {key:'from', label:'鍘熻礋璐ｄ汉', type:'text'},
      {key:'to', label:'鏂拌礋璐ｄ汉', type:'text'},
      {key:'date', label:'鏃ユ湡', type:'text'},
      {key:'status', label:'鐘舵€?, type:'select', options:['宸插畬鎴?,'杩涜涓?,'宸插彇娑?]},
      {key:'summary', label:'鎽樿', type:'textarea'}
    ]
  },
  kpi: {
    label: '馃搳 KPI鏁版嵁琛?,
    desc: '椤圭洰鏈堝害KPI鏁版嵁锛屽寘鍚攢鍞銆佹垚鏈€佽垂鏁堟瘮銆佺洰鏍囪揪鎴愮巼绛夈€傜洰鏍囦笌鏉冭矗銆佹垚鏈鐞嗛〉闈緷璧栨琛ㄣ€?,
    data: KPI_HISTORY||[],
    fields: [
      {key:'date', label:'鏃ユ湡', type:'text', required:true},
      {key:'projectId', label:'椤圭洰ID', type:'text'},
      {key:'revenue', label:'閿€鍞(涓?', type:'number'},
      {key:'cost', label:'鎴愭湰(涓?', type:'number'},
      {key:'profitRate', label:'璐规晥姣?, type:'text'},
      {key:'targetRate', label:'鐩爣杈炬垚鐜?, type:'text'}
    ]
  },
  personnel: {
    label: '馃懃 浜哄憳鏁版嵁琛?,
    desc: '瀹㈡湇浜哄憳缁╂晥銆佺粍鍒礋鑽锋瘮銆佸伐浣滈噺缁熻銆佷汉鍛橀厤缃€傚鏈嶇哗鏁堢湅鏉裤€佽繍钀ユ暟鎹瓑椤甸潰渚濊禆姝よ〃銆?,
    data: AGENT_PERFORMANCE||[],
    fields: [],
    isComplex: true,
    subTables: ['agent', 'group', 'workload', 'staff']
  },
  sysconfig: {
    label: '馃攼 绯荤粺閰嶇疆琛?,
    desc: '鐢ㄦ埛璐﹀彿銆佹暟鎹潈闄愰厤缃€佺櫥褰曡褰曘€傜櫥褰曡璇併€佹潈闄愮鐞嗐€佺敤鎴风鐞嗗潎渚濊禆姝よ〃銆?,
    data: USERS||[],
    fields: [],
    isComplex: true,
    subTables: ['users', 'permissions', 'loginlogs']
  },
  changelog: {
    label: '馃攳 鎿嶄綔鏃ュ織琛?,
    desc: '鎵€鏈夋暟鎹慨鏀圭殑瀹¤璁板綍锛堢郴缁熻嚜鍔ㄧ淮鎶わ紝浠呭彲鏌ョ湅锛夈€傝褰曡皝鍦ㄤ綍鏃朵慨鏀逛簡鍝潯鏁版嵁鐨勫摢涓瓧娈点€?,
    data: DATA_CHANGE_LOG||[],
    fields: [
      {key:'changedAt', label:'鏃堕棿', type:'text'},
      {key:'changedBy', label:'鎿嶄綔浜?, type:'text'},
      {key:'tableName', label:'琛ㄥ悕', type:'text'},
      {key:'recordId', label:'璁板綍ID', type:'text'},
      {key:'fieldName', label:'瀛楁鍚?, type:'text'},
      {key:'oldValue', label:'鏃у€?, type:'text'},
      {key:'newValue', label:'鏂板€?, type:'text'}
    ]
  }
};

function renderSystemData(){
  // 鍗＄墖鐩綍瑙嗗浘
  if(_systemDataView === 'catalog'){
    var cardsHtml = '';
    var tables = Object.keys(SYSTEM_DATA_TABLES);
    for(var i=0; i<tables.length; i++){
      var t = SYSTEM_DATA_TABLES[tables[i]];
      var count = t.data ? t.data.length : 0;
      var bgClass = '';
      if(i%3===0) bgClass = 'sd-card-clr1';
      else if(i%3===1) bgClass = 'sd-card-clr2';
      else bgClass = 'sd-card-clr3';
      cardsHtml += ''
        +'<div class="sd-card" style="cursor:pointer;" onclick="goSystemDataDetail(\''+tables[i]+'\')">'
          +'<div class="sd-card-inner '+bgClass+'">'
            +'<div class="sd-card-icon">'+t.label.charAt(0)+t.label.charAt(1)+'</div>'
            +'<div class="sd-card-label">'+t.label.substring(2)+'</div>'
            +'<div class="sd-card-count">'+count+' 鏉¤褰?/div>'
            +'<div class="sd-card-desc">'+t.desc.substring(0,40)+'...</div>'
          +'</div>'
        +'</div>';
    }
    return `
    <div class="module-header">
      <div>
        <div class="module-title">馃梽锔?绯荤粺鏁版嵁绠＄悊</div>
        <div style="font-size:12px;color:var(--c-text-3);margin-top:4px;">缁熶竴鏁版嵁绠＄悊涓績 路 鎵€鏈夋暟鎹殑鍞竴鍏ュ彛涓庣淮鎶や腑蹇?/div>
      </div>
    </div>
    <div class="sd-cards-grid">${cardsHtml}</div>
    `;
  }

  // 琛ㄦ牸璇︽儏瑙嗗浘
  var tableDef = SYSTEM_DATA_TABLES[_systemDataTab];
  if(!tableDef) { _systemDataView='catalog'; return renderSystemData(); }

  var isLog = _systemDataTab === 'changelog';
  var isComplex = tableDef.isComplex;

  var allData = tableDef.data || [];
  var filteredData = allData;
  if(_systemDataSearchKeyword && !isLog){
    var kw = _systemDataSearchKeyword.toLowerCase();
    filteredData = allData.filter(function(row){
      return JSON.stringify(row).toLowerCase().indexOf(kw) >= 0;
    });
  }
  var totalRows = filteredData.length;
  var totalPages = Math.ceil(totalRows / _systemDataPageSize);
  if(_systemDataPage > totalPages) _systemDataPage = totalPages || 1;
  var startIdx = (_systemDataPage-1) * _systemDataPageSize;
  var endIdx = Math.min(startIdx + _systemDataPageSize, totalRows);
  var pageData = filteredData.slice(startIdx, endIdx);

  var headers = [];
  if(_systemDataTab === 'projects'){
    headers = ['<input type="checkbox" onchange="toggleSelectAll(this)">','椤圭洰缂栧彿','椤圭洰鍚嶇О','鍝佺墝/鍝佺被','椤圭洰绫诲瀷','鑱屽満','璐熻矗浜?,'鐘舵€?,'鍋ュ悍搴?,'骞冲彴'];
  } else if(_systemDataTab === 'operations'){
    headers = ['<input type="checkbox" onchange="toggleSelectAll(this)">','椤圭洰ID','宸ュ崟閲?,'杞寲鏁?,'瀹㈠崟浠?,'婊℃剰搴?,'鍝嶅簲鏃堕棿','澶勭悊鏃堕暱','鐘舵€?];
  } else if(_systemDataTab === 'issues'){
    headers = ['<input type="checkbox" onchange="toggleSelectAll(this)">','缂栧彿','椤圭洰','绫诲瀷','鎻忚堪','浼樺厛绾?,'璐ｄ换浜?,'鐘舵€?,'鏉ユ簮'];
  } else if(_systemDataTab === 'knowledge'){
    headers = ['<input type="checkbox" onchange="toggleSelectAll(this)">','ID','鏍囬','绫诲瀷','鏉冮檺','娴忚閲?,'涓嬭浇閲?,'鏇存柊鏃堕棿'];
  } else if(_systemDataTab === 'handovers'){
    headers = ['<input type="checkbox" onchange="toggleSelectAll(this)">','ID','椤圭洰ID','椤圭洰鍚嶇О','鍘熻礋璐ｄ汉','鏂拌礋璐ｄ汉','鏃ユ湡','鐘舵€?,'鎽樿'];
  } else if(_systemDataTab === 'kpi'){
    headers = ['<input type="checkbox" onchange="toggleSelectAll(this)">','鏃ユ湡','椤圭洰ID','閿€鍞(涓?','鎴愭湰(涓?','璐规晥姣?,'鐩爣杈炬垚鐜?];
  } else if(_systemDataTab === 'changelog'){
    headers = ['鏃堕棿','鎿嶄綔浜?,'琛ㄥ悕','璁板綍ID','瀛楁鍚?,'鏃у€?,'鏂板€?];
  } else if(_systemDataTab === 'personnel' || _systemDataTab === 'sysconfig'){
    headers = ['绫诲瀷','鏁伴噺','璇存槑'];
  }

  var rowsHtml = '';
  if(_systemDataTab === 'projects' && pageData.length>0){
    rowsHtml = pageData.map(function(p,i){
      var ri = allData.indexOf(p);
      return '<tr>'
        +'<td><input type="checkbox" class="row-checkbox" data-idx="'+ri+'"></td>'
        +'<td style="font-weight:500;cursor:pointer;" onclick="startInlineEdit(this,\'projects\','+ri+',\'id\')">'+p.id+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'projects\','+ri+',\'name\')">'+p.name+'</td>'
        +'<td>'+(p.brand||'')+'/'+(p.category||'')+'</td>'
        +'<td><span class="badge '+(p.serviceMode==='TP椤圭洰'?'badge-blue':p.serviceMode==='DP椤圭洰'?'badge-green':'badge-orange')+'">'+p.serviceMode+'</span></td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'projects\','+ri+',\'workplace\')">'+(p.workplace||'')+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'projects\','+ri+',\'pm\')">'+(p.pm||'')+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'projects\','+ri+',\'status\')">'+(p.status||'')+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'projects\','+ri+',\'health\')">'+(p.health||'')+'</td>'
        +'<td>'+(p.customerPlatforms||'--').replace(/,/g,' / ')+'</td>'
        +'<td style="text-align:center;white-space:nowrap;">'
          +'<button class="btn btn-sm" onclick="editSystemDataRow(\'projects\','+ri+')">鉁忥笍 缂栬緫</button> '
          +'<button class="btn btn-sm" style="color:#fff;background:#e74c3c;" onclick="deleteSystemDataRow(\'projects\','+ri+')">馃棏 鍒犻櫎</button>'
        +'</td></tr>';
    }).join('');
  } else if(_systemDataTab === 'operations' && pageData.length>0){
    rowsHtml = pageData.map(function(o,i){
      var ri = allData.indexOf(o);
      return '<tr>'
        +'<td><input type="checkbox" class="row-checkbox" data-idx="'+ri+'"></td>'
        +'<td style="font-weight:500;cursor:pointer;" onclick="startInlineEdit(this,\'operations\','+ri+',\'projectId\')">'+o.projectId+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'operations\','+ri+',\'ticketVol\')">'+o.ticketVol+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'operations\','+ri+',\'convCount\')">'+o.convCount+'</td>'
        +'<td>楼<span style="cursor:pointer;" onclick="startInlineEdit(this,\'operations\','+ri+',\'avgPrice\')">'+o.avgPrice+'</span></td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'operations\','+ri+',\'csat\')">'+o.csat+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'operations\','+ri+',\'responseTime\')">'+o.responseTime+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'operations\','+ri+',\'handleDuration\')">'+o.handleDuration+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'operations\','+ri+',\'status\')">'+o.status+'</td>'
        +'<td style="text-align:center;white-space:nowrap;">'
          +'<button class="btn btn-sm" onclick="editSystemDataRow(\'operations\','+ri+')">鉁忥笍 缂栬緫</button> '
          +'<button class="btn btn-sm" style="color:#fff;background:#e74c3c;" onclick="deleteSystemDataRow(\'operations\','+ri+')">馃棏 鍒犻櫎</button>'
        +'</td></tr>';
    }).join('');
  } else if(_systemDataTab === 'issues' && pageData.length>0){
    rowsHtml = pageData.map(function(iss,i){
      var ri = allData.indexOf(iss);
      return '<tr>'
        +'<td><input type="checkbox" class="row-checkbox" data-idx="'+ri+'"></td>'
        +'<td style="font-weight:500;">I'+String(iss.id).padStart(3,'0')+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'issues\','+ri+',\'projectName\')">'+iss.projectName+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'issues\','+ri+',\'type\')">'+iss.type+'</td>'
        +'<td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;cursor:pointer;" onclick="startInlineEdit(this,\'issues\','+ri+',\'desc\')">'+iss.desc+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'issues\','+ri+',\'priority\')">'+iss.priority+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'issues\','+ri+',\'assignee\')">'+iss.assignee+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'issues\','+ri+',\'status\')">'+iss.status+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'issues\','+ri+',\'source\')">'+iss.source+'</td>'
        +'<td style="text-align:center;white-space:nowrap;">'
          +'<button class="btn btn-sm" onclick="editSystemDataRow(\'issues\','+ri+')">鉁忥笍 缂栬緫</button> '
          +'<button class="btn btn-sm" style="color:#fff;background:#e74c3c;" onclick="deleteSystemDataRow(\'issues\','+ri+')">馃棏 鍒犻櫎</button>'
        +'</td></tr>';
    }).join('');
  } else if(_systemDataTab === 'knowledge' && pageData.length>0){
    rowsHtml = pageData.map(function(k,i){
      var ri = allData.indexOf(k);
      return '<tr>'
        +'<td><input type="checkbox" class="row-checkbox" data-idx="'+ri+'"></td>'
        +'<td style="font-weight:500;cursor:pointer;" onclick="startInlineEdit(this,\'knowledge\','+ri+',\'id\')">'+k.id+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'knowledge\','+ri+',\'title\')">'+k.title+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'knowledge\','+ri+',\'type\')">'+k.type+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'knowledge\','+ri+',\'permission\')">'+k.permission+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'knowledge\','+ri+',\'views\')">'+k.views+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'knowledge\','+ri+',\'downloads\')">'+k.downloads+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'knowledge\','+ri+',\'updateTime\')">'+k.updateTime+'</td>'
        +'<td style="text-align:center;white-space:nowrap;">'
          +'<button class="btn btn-sm" onclick="editSystemDataRow(\'knowledge\','+ri+')">鉁忥笍 缂栬緫</button> '
          +'<button class="btn btn-sm" style="color:#fff;background:#e74c3c;" onclick="deleteSystemDataRow(\'knowledge\','+ri+')">馃棏 鍒犻櫎</button>'
        +'</td></tr>';
    }).join('');
  } else if(_systemDataTab === 'handovers' && pageData.length>0){
    rowsHtml = pageData.map(function(h,i){
      var ri = allData.indexOf(h);
      return '<tr>'
        +'<td><input type="checkbox" class="row-checkbox" data-idx="'+ri+'"></td>'
        +'<td style="font-weight:500;cursor:pointer;" onclick="startInlineEdit(this,\'handovers\','+ri+',\'id\')">'+h.id+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'handovers\','+ri+',\'projectId\')">'+h.projectId+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'handovers\','+ri+',\'projectName\')">'+h.projectName+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'handovers\','+ri+',\'from\')">'+h.from+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'handovers\','+ri+',\'to\')">'+h.to+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'handovers\','+ri+',\'date\')">'+h.date+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'handovers\','+ri+',\'status\')">'+h.status+'</td>'
        +'<td style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;cursor:pointer;" onclick="startInlineEdit(this,\'handovers\','+ri+',\'summary\')">'+h.summary+'</td>'
        +'<td style="text-align:center;white-space:nowrap;">'
          +'<button class="btn btn-sm" onclick="editSystemDataRow(\'handovers\','+ri+')">鉁忥笍 缂栬緫</button> '
          +'<button class="btn btn-sm" style="color:#fff;background:#e74c3c;" onclick="deleteSystemDataRow(\'handovers\','+ri+')">馃棏 鍒犻櫎</button>'
        +'</td></tr>';
    }).join('');
  } else if(_systemDataTab === 'kpi' && pageData.length>0){
    rowsHtml = pageData.map(function(k,i){
      var ri = allData.indexOf(k);
      return '<tr>'
        +'<td><input type="checkbox" class="row-checkbox" data-idx="'+ri+'"></td>'
        +'<td style="font-weight:500;cursor:pointer;" onclick="startInlineEdit(this,\'kpi\','+ri+',\'date\')">'+k.date+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'kpi\','+ri+',\'projectId\')">'+k.projectId+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'kpi\','+ri+',\'revenue\')">'+(k.revenue||0)+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'kpi\','+ri+',\'cost\')">'+(k.cost||0)+'</td>'
        +'<td style="cursor:pointer;" onclick="startInlineEdit(this,\'kpi\','+ri+',\'profitRate\')">'+(k.profitRate||'')+'</td>'
        +'<td><span style="cursor:pointer;" onclick="startInlineEdit(this,\'kpi\','+ri+',\'targetRate\')">'+(k.targetRate||'')+'</span>%</td>'
        +'<td style="text-align:center;white-space:nowrap;">'
          +'<button class="btn btn-sm" onclick="editSystemDataRow(\'kpi\','+ri+')">鉁忥笍 缂栬緫</button> '
          +'<button class="btn btn-sm" style="color:#fff;background:#e74c3c;" onclick="deleteSystemDataRow(\'kpi\','+ri+')">馃棏 鍒犻櫎</button>'
        +'</td></tr>';
    }).join('');
  } else if(_systemDataTab === 'changelog' && pageData.length>0){
    rowsHtml = pageData.map(function(l,i){
      return '<tr>'
        +'<td style="font-size:12px;">'+l.changedAt+'</td>'
        +'<td>'+l.changedBy+'</td>'
        +'<td>'+l.tableName+'</td>'
        +'<td>'+l.recordId+'</td>'
        +'<td>'+l.fieldName+'</td>'
        +'<td style="color:#e74c3c;font-size:12px;">'+l.oldValue+'</td>'
        +'<td style="color:#27ae60;font-size:12px;">'+l.newValue+'</td>'
        +'</tr>';
    }).join('');
  } else if(_systemDataTab === 'personnel'){
    var agentCount = (AGENT_PERFORMANCE||[]).length;
    var groupCount = (GROUP_LOAD_RATIO||[]).length;
    var workloadCount = (WORKLOAD_DATA||[]).length;
    var staffCount = (STAFF_CONFIG||[]).length;
    rowsHtml = '<tr><td>瀹㈡湇缁╂晥鏁版嵁</td><td>'+agentCount+' 鏉?/td><td>AGENT_PERFORMANCE 鈥?鍞墠/鍞悗/缁煎悎瀹㈡湇鏈堝害缁╂晥</td><td style="text-align:center;"><button class="btn btn-sm" onclick="alert(\'璇︾粏鏁版嵁鏌ョ湅鍔熻兘寮€鍙戜腑\')">鏌ョ湅</button></td></tr>'
      +'<tr><td>缁勫埆璐熻嵎姣?/td><td>'+groupCount+' 鏉?/td><td>GROUP_LOAD_RATIO 鈥?A缁?B缁勬湀搴﹁礋鑽?/td><td style="text-align:center;"><button class="btn btn-sm" onclick="alert(\'璇︾粏鏁版嵁鏌ョ湅鍔熻兘寮€鍙戜腑\')">鏌ョ湅</button></td></tr>'
      +'<tr><td>宸ヤ綔閲忔暟鎹?/td><td>'+workloadCount+' 鏉?/td><td>WORKLOAD_DATA 鈥?鍚勭被鍨嬪伐浣滈噺鍜屽崰姣旂粺璁?/td><td style="text-align:center;"><button class="btn btn-sm" onclick="alert(\'璇︾粏鏁版嵁鏌ョ湅鍔熻兘寮€鍙戜腑\')">鏌ョ湅</button></td></tr>'
      +'<tr><td>瀹㈡湇閰嶇疆鏁版嵁</td><td>'+staffCount+' 鏉?/td><td>STAFF_CONFIG 鈥?瑙掕壊/浜烘暟/鍗犳瘮/鑱屽満閰嶇疆</td><td style="text-align:center;"><button class="btn btn-sm" onclick="alert(\'璇︾粏鏁版嵁鏌ョ湅鍔熻兘寮€鍙戜腑\')">鏌ョ湅</button></td></tr>';
  } else if(_systemDataTab === 'sysconfig'){
    var userCount = (USERS||[]).length;
    var permCount = (DATA_PERMISSIONS||[]).length;
    var logCount = JSON.parse(localStorage.getItem('chansee_login_logs')||'[]').length;
    rowsHtml = '<tr><td>鐢ㄦ埛鏁版嵁</td><td>'+userCount+' 鏉?/td><td>USERS 鈥?绯荤粺鐢ㄦ埛銆佹樀绉般€佽鑹层€佹潈闄愮瓑</td><td style="text-align:center;"><button class="btn btn-sm" onclick="alert(\'璇︾粏鏁版嵁鏌ョ湅鍔熻兘寮€鍙戜腑\')">鏌ョ湅</button></td></tr>'
      +'<tr><td>鏁版嵁鏉冮檺閰嶇疆</td><td>'+permCount+' 鏉?/td><td>DATA_PERMISSIONS 鈥?瑙掕壊绾ф暟鎹搷浣滄潈闄?/td><td style="text-align:center;"><button class="btn btn-sm" onclick="alert(\'璇︾粏鏁版嵁鏌ョ湅鍔熻兘寮€鍙戜腑\')">鏌ョ湅</button></td></tr>'
      +'<tr><td>鐧诲綍璁板綍</td><td>'+logCount+' 鏉?/td><td>LOGIN_LOGS 鈥?鐢ㄦ埛鐧诲綍鍘嗗彶璁板綍</td><td style="text-align:center;"><button class="btn btn-sm" onclick="alert(\'璇︾粏鏁版嵁鏌ョ湅鍔熻兘寮€鍙戜腑\')">鏌ョ湅</button></td></tr>';
  } else {
    rowsHtml = '<tr><td colspan="'+(headers.length+1)+'" style="text-align:center;padding:40px;color:#8899a6;">鏆傛棤鏁版嵁璁板綍</td></tr>';
  }

  var paginationHtml = '';
  if(totalPages > 1){
    paginationHtml = '<div style="display:flex;justify-content:space-between;align-items:center;margin-top:16px;font-size:13px;color:#64748b;">'
      +'<div>鏄剧ず绗?'+(startIdx+1)+'-'+endIdx+' 鏉★紝鍏?'+totalRows+' 鏉¤褰?/div>'
      +'<div style="display:flex;gap:4px;">'
        +'<button class="btn btn-sm" '+(_systemDataPage<=1?'disabled style="opacity:0.5;"':'')+' onclick="_systemDataPage=1;renderModule(\'systemData\')">棣栭〉</button>'
        +'<button class="btn btn-sm" '+(_systemDataPage<=1?'disabled style="opacity:0.5;"':'')+' onclick="_systemDataPage--;renderModule(\'systemData\')">涓婁竴椤?/button>';
    for(var p=1; p<=totalPages; p++){
      if(p===1||p===totalPages||Math.abs(p-_systemDataPage)<=2){
        paginationHtml += '<button class="btn btn-sm" '+(p===_systemDataPage?'style="background:#185FA5;color:#fff;"':'')+' onclick="_systemDataPage='+p+';renderModule(\'systemData\')">'+p+'</button>';
      } else if(Math.abs(p-_systemDataPage)===3){
        paginationHtml += '<span style="padding:4px 8px;">...</span>';
      }
    }
    paginationHtml += '<button class="btn btn-sm" '+(_systemDataPage>=totalPages?'disabled style="opacity:0.5;"':'')+' onclick="_systemDataPage++;renderModule(\'systemData\')">涓嬩竴椤?/button>'
        +'<button class="btn btn-sm" '+(_systemDataPage>=totalPages?'disabled style="opacity:0.5;"':'')+' onclick="_systemDataPage='+totalPages+';renderModule(\'systemData\')">鏈〉</button>'
      +'</div></div>';
  }

  return `
  <div class="module-header">
    <div>
      <div class="module-title"><a href="javascript:" onclick="backSystemDataCatalog()" style="color:#185FA5;text-decoration:none;font-size:14px;">鈫?杩斿洖鏁版嵁琛ㄧ洰褰?/a> &nbsp; ${tableDef.label}</div>
      <div style="font-size:12px;color:var(--c-text-3);margin-top:4px;">${tableDef.desc}</div>
    </div>
  </div>

  <div style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;align-items:center;">
    ${!isLog&&!isComplex?'<button class="btn btn-sm" onclick="addSystemDataRow()">鉃?鏂板</button>':''}
    <button class="btn btn-sm" onclick="exportSystemData()">馃摜 瀵煎嚭Excel</button>
    ${!isLog&&!isComplex?'<button class="btn btn-sm" onclick="importSystemData()">馃搨 瀵煎叆Excel</button>':''}
    ${!isLog&&!isComplex?'<button class="btn btn-sm" style="color:#e74c3c;" onclick="batchDeleteSystemData()">馃棏 鎵归噺鍒犻櫎</button>':''}
    <span style="flex:1;"></span>
    ${!isLog?'<input type="text" id="system-data-search" placeholder="馃攳 鎼滅储..." style="padding:7px 12px;border-radius:8px;border:1px solid #d0d7de;font-size:13px;width:200px;" value="'+_systemDataSearchKeyword+'">':''}
    ${!isLog?'<button class="btn btn-sm" onclick="searchSystemData()">鎼滅储</button><button class="btn btn-sm" onclick="_systemDataSearchKeyword=\'\';_systemDataPage=1;var s=document.getElementById(\'system-data-search\');if(s)s.value=\'\';renderModule(\'systemData\')">娓呴櫎</button>':''}
    <span style="background:linear-gradient(135deg,#f0fdfa 0%,#eff6ff 100%);border-radius:8px;padding:6px 12px;font-size:13px;color:#185FA5;font-weight:600;">${allData.length} 鏉¤褰?/span>
  </div>

  <div class="card" style="overflow-x:auto;padding:0;">
    <table class="data-table" style="width:100%;font-size:13px;margin:0;">
      <thead><tr style="background:#f8fafc;">${headers.map(function(h){return '<th style="padding:10px 12px;text-align:left;font-weight:600;color:#374151;border-bottom:2px solid #e5e7eb;">'+h+'</th>';}).join('')}${isLog||isComplex?'':'<th style="padding:10px 12px;text-align:center;font-weight:600;color:#374151;border-bottom:2px solid #e5e7eb;width:130px;">鎿嶄綔</th>'}</tr></thead>
      <tbody id="system-data-tbody">${rowsHtml}</tbody>
    </table>
  </div>
  ${paginationHtml}
  `;
}

// 浠庣湅鏉胯烦杞埌绯荤粺鏁版嵁绠＄悊瀵瑰簲琛?function goToSystemDataTable(key){
  // 楂樹寒渚ц竟鏍?绯荤粺鏁版嵁绠＄悊"
  document.querySelectorAll('.nav-item').forEach(function(i){i.classList.remove('active');});
  var nav = document.querySelector('.nav-item[data-module="systemData"]');
  if(nav){
    nav.classList.add('active');
    var sec = nav.closest('.nav-section');
    if(sec && sec.classList.contains('collapsed')) sec.classList.remove('collapsed');
  }
  _systemDataView = 'detail';
  _systemDataTab = key;
  _systemDataPage = 1;
  _systemDataSearchKeyword = '';
  renderModule('systemData');
}

function goSystemDataDetail(key){
  _systemDataView = 'detail';
  _systemDataTab = key;
  _systemDataPage = 1;
  _systemDataSearchKeyword = '';
  renderModule('systemData');
}

function backSystemDataCatalog(){
  _systemDataView = 'catalog';
  renderModule('systemData');
}

function switchSystemDataTab(key){
  _systemDataView = 'detail';
  _systemDataTab = key;
  _systemDataPage = 1;
  _systemDataSearchKeyword = '';
  renderModule('systemData');
}

function searchSystemData(){
  var input = document.getElementById('system-data-search');
  _systemDataSearchKeyword = input ? input.value : '';
  _systemDataPage = 1;
  renderModule('systemData');
}

function clearSystemDataSearch(){
  _systemDataSearchKeyword = '';
  var input = document.getElementById('system-data-search');
  if(input) input.value = '';
  _systemDataPage = 1;
  renderModule('systemData');
}

function toggleSelectAll(masterCheckbox){
  var checkboxes = document.querySelectorAll('.row-checkbox');
  checkboxes.forEach(function(cb){
    cb.checked = masterCheckbox.checked;
  });
}

// localStorage key 鏄犲皠
var _SD_LS_MAP = {
  projects: 'chansee_projects',
  operations: 'chansee_operations',
  issues: 'chansee_issues',
  knowledge: 'chansee_knowledge',
  handovers: 'chansee_handovers',
  kpi: 'chansee_kpi_history',
  changelog: 'chansee_data_change_log'
};

function _saveSystemData(tableKey) {
  var lsKey = _SD_LS_MAP[tableKey];
  if (!lsKey) return;
  var tableDef = SYSTEM_DATA_TABLES[tableKey];
  if (!tableDef || !tableDef.data) return;
  safeSetItem(lsKey, JSON.stringify(tableDef.data));
}

// ===== 琛屽唴缂栬緫锛圓irtable/Notion 椋庢牸锛?=====
window.startInlineEdit = function(cell, tableKey, idx, fieldKey) {
  if (cell.querySelector('input,select')) return; // 宸茬粡鍦ㄧ紪杈戜腑
  var tableDef = SYSTEM_DATA_TABLES[tableKey];
  if (!tableDef || !tableDef.fields || !tableDef.data) return;
  var fieldDef = null;
  for (var i = 0; i < tableDef.fields.length; i++) {
    if (tableDef.fields[i].key === fieldKey) { fieldDef = tableDef.fields[i]; break; }
  }
  if (!fieldDef) return;
  var oldVal = tableDef.data[idx][fieldKey];
  if (oldVal === undefined || oldVal === null) oldVal = '';
  var w = cell.offsetWidth;
  if (fieldDef.type === 'select' && fieldDef.options) {
    var opts = '';
    for (var j = 0; j < fieldDef.options.length; j++) {
      var sel = oldVal == fieldDef.options[j] ? ' selected' : '';
      opts += '<option value="'+fieldDef.options[j]+'"'+sel+'>'+fieldDef.options[j]+'</option>';
    }
    cell.innerHTML = '<select style="width:'+w+'px;padding:4px;border:2px solid #185FA5;border-radius:4px;font-size:13px;background:#fff;" onblur="saveInlineEdit(this,\''+tableKey+'\','+idx+',\''+fieldKey+'\')" onchange="saveInlineEdit(this,\''+tableKey+'\','+idx+',\''+fieldKey+'\')">'+opts+'</select>';
    cell.querySelector('select').focus();
  } else {
    var safeVal = String(oldVal).replace(/"/g,'&quot;').replace(/</g,'&lt;');
    cell.innerHTML = '<input type="text" style="width:'+w+'px;padding:4px 6px;border:2px solid #185FA5;border-radius:4px;font-size:13px;" value="'+safeVal+'" onblur="saveInlineEdit(this,\''+tableKey+'\','+idx+',\''+fieldKey+'\')" onkeydown="if(event.key===\'Enter\')saveInlineEdit(this,\''+tableKey+'\','+idx+',\''+fieldKey+'\')">';
    var inp = cell.querySelector('input');
    if (inp) { inp.focus(); inp.select(); }
  }
};

window.saveInlineEdit = function(input, tableKey, idx, fieldKey) {
  var val = input.value;
  var tableDef = SYSTEM_DATA_TABLES[tableKey];
  if (!tableDef || !tableDef.data) return;
  var fieldDef = null;
  for (var i = 0; i < (tableDef.fields||[]).length; i++) {
    if (tableDef.fields[i].key === fieldKey) { fieldDef = tableDef.fields[i]; break; }
  }
  if (fieldDef && fieldDef.type === 'number' && val !== '') {
    val = parseFloat(val) || 0;
  }
  tableDef.data[idx][fieldKey] = val;
  _saveSystemData(tableKey);
  renderModule('systemData');
};

function addSystemDataRow() {
  var tableKey = _systemDataTab;
  var tableDef = SYSTEM_DATA_TABLES[tableKey];
  if (!tableDef || !tableDef.fields || tableDef.fields.length === 0) {
    alert('璇ユ暟鎹〃涓嶆敮鎸佹柊澧炴搷浣?); return;
  }
  showSystemDataForm(tableKey, null, tableDef.fields);
}

function editSystemDataRow(tableKey, idx) {
  var tableDef = SYSTEM_DATA_TABLES[tableKey];
  if (!tableDef || !tableDef.data || !tableDef.fields) return;
  var record = tableDef.data[idx];
  if (!record) return;
  showSystemDataForm(tableKey, record, tableDef.fields, idx);
}

function showSystemDataForm(tableKey, record, fields, editIdx) {
  var isEdit = record !== null && record !== undefined;
  var tableDef = SYSTEM_DATA_TABLES[tableKey];
  var formHtml = '';
  for (var i = 0; i < fields.length; i++) {
    var f = fields[i];
    var val = record ? (record[f.key] || '') : '';
    var req = f.required ? ' required' : '';
    var labelH = '<label style="display:block;font-size:13px;font-weight:500;color:#374151;margin-bottom:4px;">' + f.label + (f.required ? ' <span style="color:#e74c3c;">*</span>' : '') + '</label>';
    if (f.type === 'select' && f.options) {
      var opts = '<option value="">-- 璇烽€夋嫨 --</option>';
      for (var j = 0; j < f.options.length; j++) {
        var sel = val === f.options[j] ? ' selected' : '';
        opts += '<option value="' + f.options[j] + '"' + sel + '>' + f.options[j] + '</option>';
      }
      formHtml += '<div style="margin-bottom:12px;">' + labelH + '<select style="width:100%;padding:8px;border:1px solid #d0d7de;border-radius:6px;font-size:13px;" data-field="' + f.key + '"' + req + '>' + opts + '</select></div>';
    } else if (f.type === 'textarea') {
      formHtml += '<div style="margin-bottom:12px;">' + labelH + '<textarea style="width:100%;padding:8px;border:1px solid #d0d7de;border-radius:6px;font-size:13px;min-height:60px;" data-field="' + f.key + '"' + req + '>' + val + '</textarea></div>';
    } else if (f.type === 'number') {
      formHtml += '<div style="margin-bottom:12px;">' + labelH + '<input type="number" style="width:100%;padding:8px;border:1px solid #d0d7de;border-radius:6px;font-size:13px;" data-field="' + f.key + '" value="' + val + '"' + req + '></div>';
    } else {
      var safeVal = val ? val.toString().replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;') : '';
      formHtml += '<div style="margin-bottom:12px;">' + labelH + '<input type="text" style="width:100%;padding:8px;border:1px solid #d0d7de;border-radius:6px;font-size:13px;" data-field="' + f.key + '" value="' + safeVal + '"' + req + '></div>';
    }
  }
  var overlay = document.getElementById('modal-overlay');
  var titleEl = document.getElementById('modal-title');
  var body = document.getElementById('modal-body');
  if (!overlay || !titleEl || !body) { alert('寮圭獥缁勪欢鏈壘鍒?); return; }
  titleEl.textContent = isEdit ? '缂栬緫鏁版嵁' : '鏂板鏁版嵁';
  body.innerHTML = '<div style="padding:24px;max-height:60vh;overflow-y:auto;">' +
    '<div style="font-size:13px;color:#64748b;margin-bottom:16px;">鏁版嵁琛細' + tableDef.label + '</div>' +
    formHtml +
    '<div style="display:flex;gap:12px;justify-content:flex-end;margin-top:20px;padding-top:16px;border-top:1px solid #e5e7eb;">' +
      '<button class="btn" onclick="document.getElementById(\'modal-overlay\').classList.add(\'hidden\')">鍙栨秷</button>' +
      '<button class="btn btn-primary" onclick="submitSystemDataForm(\'' + tableKey + '\', ' + (isEdit ? editIdx : -1) + ')">' + (isEdit ? '淇濆瓨淇敼' : '纭鏂板') + '</button>' +
    '</div></div>';
  overlay.classList.remove('hidden');
}

window.submitSystemDataForm = function (tableKey, editIdx) {
  var tableDef = SYSTEM_DATA_TABLES[tableKey];
  if (!tableDef || !tableDef.fields) return;
  var fields = tableDef.fields;
  var isEdit = editIdx >= 0;
  var newRecord = {};
  for (var i = 0; i < fields.length; i++) {
    var f = fields[i];
    var el = document.querySelector('#modal-body [data-field="' + f.key + '"]');
    var val = el ? el.value : '';
    if (f.required && !val.trim()) { alert('璇峰～鍐欙細' + f.label); return; }
    if (f.type === 'number' && val) { val = parseFloat(val); if (isNaN(val)) val = 0; }
    newRecord[f.key] = val;
  }
  if (isEdit) {
    for (var key in newRecord) { tableDef.data[editIdx][key] = newRecord[key]; }
  } else {
    tableDef.data.push(newRecord);
  }
  _saveSystemData(tableKey);
  document.getElementById('modal-overlay').classList.add('hidden');
  renderModule('systemData');
  if (typeof showToast === 'function') showToast(isEdit ? '宸蹭繚瀛樹慨鏀? : '宸叉柊澧炶褰?);
};

function deleteSystemDataRow(tableKey, idx) {
  if (!confirm('纭畾瑕佸垹闄よ繖鏉¤褰曞悧锛熷垹闄ゅ悗涓嶅彲鎭㈠銆?)) return;
  var tableDef = SYSTEM_DATA_TABLES[tableKey];
  if (!tableDef || !tableDef.data) return;
  tableDef.data.splice(idx, 1);
  _saveSystemData(tableKey);
  renderModule('systemData');
  if (typeof showToast === 'function') showToast('宸插垹闄よ褰?);
}

function batchDeleteSystemData() {
  var checkboxes = document.querySelectorAll('.row-checkbox:checked');
  if (checkboxes.length === 0) { alert('璇峰厛閫夋嫨瑕佸垹闄ょ殑璁板綍'); return; }
  if (!confirm('纭畾瑕佸垹闄ら€変腑鐨?' + checkboxes.length + ' 鏉¤褰曞悧锛熷垹闄ゅ悗涓嶅彲鎭㈠銆?)) return;
  var tableKey = _systemDataTab;
  var tableDef = SYSTEM_DATA_TABLES[tableKey];
  if (!tableDef || !tableDef.data) return;
  var indices = [];
  for (var i = 0; i < checkboxes.length; i++) { indices.push(parseInt(checkboxes[i].getAttribute('data-idx'))); }
  indices.sort(function (a, b) { return b - a; });
  for (var i = 0; i < indices.length; i++) { tableDef.data.splice(indices[i], 1); }
  _saveSystemData(tableKey);
  renderModule('systemData');
  if (typeof showToast === 'function') showToast('宸叉壒閲忓垹闄?' + indices.length + ' 鏉¤褰?);
}

function exportSystemData() {
  var tableKey = _systemDataTab;
  var tableDef = SYSTEM_DATA_TABLES[tableKey];
  if (!tableDef || !tableDef.fields || tableDef.fields.length === 0) { alert('璇ユ暟鎹〃涓嶆敮鎸佸鍑?); return; }
  var data = tableDef.data || [];
  if (data.length === 0) { alert('娌℃湁鏁版嵁鍙鍑?); return; }
  var fields = tableDef.fields;
  var headers = [];
  var rows = [];
  for (var i = 0; i < fields.length; i++) { headers.push(fields[i].label); }
  for (var i = 0; i < data.length; i++) {
    var row = [];
    for (var j = 0; j < fields.length; j++) { var v = data[i][fields[j].key]; row.push(v !== undefined ? v : ''); }
    rows.push(row);
  }
  var fname = (tableDef.label.replace(/[馃搵馃搱馃悰馃摎鈴仇煋婐煈ヰ煍愷煍峕/g,'').trim() || tableKey) + '_' + new Date().toISOString().slice(0, 10) + '.xlsx';
  exportToXlsx(fname, headers, rows);
}

function importSystemData() {
  var tableKey = _systemDataTab;
  var tableDef = SYSTEM_DATA_TABLES[tableKey];
  if (!tableDef || !tableDef.fields || tableDef.fields.length === 0) { alert('璇ユ暟鎹〃涓嶆敮鎸佸鍏?); return; }
  var input = document.createElement('input');
  input.type = 'file';
  input.accept = '.csv,.xlsx,.xls';
  input.onchange = function (e) {
    var file = e.target.files[0];
    if (!file) return;
    var reader = new FileReader();
    reader.onload = function (ev) {
      var data = new Uint8Array(ev.target.result);
      var workbook = XLSX.read(data, { type: 'array' });
      var sheet = workbook.Sheets[workbook.SheetNames[0]];
      var rows = XLSX.utils.sheet_to_json(sheet, { header: 1 });
      if (rows.length < 2) { alert('鏂囦欢娌℃湁鏁版嵁琛?); return; }
      var fields = tableDef.fields;
      var importCount = 0;
      for (var i = 1; i < rows.length; i++) {
        var row = rows[i];
        if (!row || row.length === 0) continue;
        var record = {};
        for (var j = 0; j < fields.length && j < row.length; j++) {
          var val = row[j];
          if (fields[j].type === 'number') { val = parseFloat(val) || 0; }
          record[fields[j].key] = val;
        }
        var pkField = fields[0].key;
        var exists = false;
        if (record[pkField]) {
          for (var k = 0; k < tableDef.data.length; k++) {
            if (tableDef.data[k][pkField] == record[pkField]) {
              for (var key in record) { tableDef.data[k][key] = record[key]; }
              exists = true;
              break;
            }
          }
        }
        if (!exists) { tableDef.data.push(record); }
        importCount++;
      }
      _saveSystemData(tableKey);
      renderModule('systemData');
      if (typeof showToast === 'function') showToast('宸插鍏?' + importCount + ' 鏉¤褰?);
    };
    reader.readAsArrayBuffer(file);
  };
  input.click();
}

