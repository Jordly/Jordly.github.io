// 榛樿鏉冮檺閰嶇疆锛?瑙掕壊锛?绉嶆搷浣?scope锛?// visible/view/edit/import/export/manage : true/false ; scope: "all" | "own"
function permObj(v,ed,im,ex,mg,sc){
  var o = { visible:v||false, view:v||false };
  if(ed!==undefined) o.edit=ed; else o.edit=v||false;
  o.import=im||false; o.export=ex||false; o.manage=mg||false;
  o.scope=sc||'all'; return o;
}
// 缂╁啓: permObj(view, edit, import, export, manage, scope)
var ALL  = permObj(true,true,true,true,true,'all');      // 鍏ㄦ潈闄?var EDIT = permObj(true,true,false,true,false,'all');    // 鍙紪杈戝彲瀵煎嚭
var VIEW = permObj(true,false,false,true,false,'all');   // 鍙湅鍙鍑?var VOWN = permObj(true,false,false,true,false,'own');   // 鍙湅鑷繁鍙鍑?var RO   = permObj(true,false,false,false,false,'own');  // 鍙鑷繁
var HIDE = permObj(false,false,false,false,false,'all'); // 闅愯棌
var MGR  = permObj(true,true,false,false,true,'all');    // 鍙紪杈戝彲绠＄悊
var EDIT_NOEXP = permObj(true,true,false,false,false,'all'); // 鍙紪杈戜笉瀵煎嚭

