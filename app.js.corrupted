// 璁板綍鏁版嵁淇敼鍘嗗彶
function addChangeLog(tableName, recordId, fieldName, oldValue, newValue) {
  try {
    const user = (typeof CURRENT_USER !== 'undefined' && CURRENT_USER) ? CURRENT_USER.username : 'admin';
    const log = {
      id: 'LOG' + Date.now(),
      tableName: tableName,
      recordId: recordId || '',
      fieldName: fieldName || '',
      oldValue: String(oldValue || ''),
      newValue: String(newValue || ''),
      changedBy: user,
      changedAt: new Date().toISOString().slice(0, 19).replace('T', ' ')
    };
    DATA_CHANGE_LOG.push(log);
    // 鍙繚鐣欐渶杩?00鏉?    if (DATA_CHANGE_LOG.length > 200) DATA_CHANGE_LOG.shift();
    localStorage.setItem('chansee_data_change_log', JSON.stringify(DATA_CHANGE_LOG));
  } catch(e) { console.error('addChangeLog error:', e); }
}

// 鏄剧ず淇敼鍘嗗彶锛堝鐢ㄧ郴缁熷脊绐楋級
function showChangeLog() {
  var overlay = document.getElementById('modal-overlay');
  var titleEl = document.getElementById('modal-title');
  var bodyEl = document.getElementById('modal-body');
  var footerEl = document.getElementById('modal-footer');
  if (!overlay || !titleEl || !bodyEl) return;

  var html = '';
  if (DATA_CHANGE_LOG.length === 0) {
    html += '<p style="color:#999;text-align:center;padding:30px 0">鏆傛棤淇敼璁板綍</p>';
    html += '<p style="color:#999;text-align:center;font-size:12px">鍦ㄣ€屾暟鎹鐞嗐€嶄腑淇敼鏁版嵁鍚庯紝淇敼璁板綍浼氳嚜鍔ㄦ樉绀哄湪杩欓噷</p>';
  } else {
    html += '<table style="width:100%;border-collapse:collapse;font-size:13px;">';
    html += '<thead><tr style="background:var(--c-bg-2,#f5f5f5)">';
    html += '<th style="padding:8px 6px;border:1px solid var(--c-border,#ddd);text-align:left">鏃堕棿</th>';
    html += '<th style="padding:8px 6px;border:1px solid var(--c-border,#ddd);text-align:left">鐢ㄦ埛</th>';
    html += '<th style="padding:8px 6px;border:1px solid var(--c-border,#ddd);text-align:left">鏁版嵁琛?/th>';
    html += '<th style="padding:8px 6px;border:1px solid var(--c-border,#ddd);text-align:left">瀛楁</th>';
    html += '<th style="padding:8px 6px;border:1px solid var(--c-border,#ddd);text-align:left">鏃у€?/th>';
    html += '<th style="padding:8px 6px;border:1px solid var(--c-border,#ddd);text-align:left">鏂板€?/th>';
    html += '</tr></thead><tbody>';

    DATA_CHANGE_LOG.slice().reverse().slice(0, 100).forEach(function(l) {
      html += '<tr>';
      html += '<td style="padding:6px;border:1px solid var(--c-border,#ddd);white-space:nowrap">' + l.changedAt + '</td>';
      html += '<td style="padding:6px;border:1px solid var(--c-border,#ddd)">' + l.changedBy + '</td>';
      html += '<td style="padding:6px;border:1px solid var(--c-border,#ddd)">' + l.tableName + '</td>';
      html += '<td style="padding:6px;border:1px solid var(--c-border,#ddd)">' + (l.fieldName || '鈥?) + '</td>';
      html += '<td style="padding:6px;border:1px solid var(--c-border,#ddd);max-width:150px;overflow:hidden;text-overflow:ellipsis">' + (l.oldValue || '鈥?) + '</td>';
      html += '<td style="padding:6px;border:1px solid var(--c-border,#ddd);max-width:150px;overflow:hidden;text-overflow:ellipsis">' + (l.newValue || '鈥?) + '</td>';
      html += '</tr>';
    });

    html += '</tbody></table>';
    html += '<p style="font-size:11px;color:#999;margin-top:10px">鍏?' + DATA_CHANGE_LOG.length + ' 鏉¤褰曪紙鏈€澶氫繚鐣?00鏉★級</p>';
  }

  titleEl.textContent = '馃搵 鏁版嵁淇敼鍘嗗彶';
  bodyEl.innerHTML = html;
  if (footerEl) footerEl.innerHTML = '<button class="btn" onclick="closeChangeLog()">鍏抽棴</button>';
  overlay.classList.remove('hidden');
}

function closeChangeLog() {
  var overlay = document.getElementById('modal-overlay');
  if (overlay) overlay.classList.add('hidden');
}

// ===== 閿洏蹇嵎閿?=====
document.addEventListener('keydown', function(e) {
  // 鍙湪椤圭洰鍩虹妗ｆ椤甸潰鐢熸晥
  if (currentModule !== 'archive') return;

  // Ctrl + F: 鑱氱劍鎼滅储妗?  if (e.ctrlKey && e.key === 'f') {
    e.preventDefault();
    var searchBox = document.getElementById('archive-search');
    if (searchBox) searchBox.focus();
  }

  // Ctrl + A: 鍏ㄩ€?鍙栨秷鍏ㄩ€?  if (e.ctrlKey && e.key === 'a') {
    e.preventDefault();
    var selectAll = document.getElementById('archive-select-all');
    if (selectAll) {
      selectAll.checked = !selectAll.checked;
      toggleArchiveSelectAll(selectAll.checked);
    }
  }

  // Delete: 鎵归噺鍒犻櫎
  if (e.key === 'Delete') {
    var checked = document.querySelectorAll('.archive-row-check:checked');
    if (checked.length > 0) {
      batchDeleteProjects();
    }
  }

  // Esc: 鍙栨秷閫夋嫨
  if (e.key === 'Escape') {
    clearArchiveSelection();
  }
});

// ===== 闂璁板綍绛涢€?=====
function filterIssueByStatus(status, el){
  issueFilterState.status = status||'all';
  // 鏇存柊鎸夐挳鏍峰紡
  var btns = document.querySelectorAll('.issue-filter-btn');
  for(var i=0;i<btns.length;i++){ btns[i].classList.remove('issue-filter-active'); }
  if(el) el.classList.add('issue-filter-active');
  renderModule('issue');
}

function filterIssues(){
  var prioritySel = document.getElementById('issue-filter-priority');
  var typeSel = document.getElementById('issue-filter-type');
  var assigneeSel = document.getElementById('issue-filter-assignee');
  var searchInput = document.getElementById('issue-search');
  issueFilterState.priority = prioritySel?prioritySel.value:'all';
  issueFilterState.type = typeSel?typeSel.value:'all';
  issueFilterState.assignee = assigneeSel?assigneeSel.value:'all';
  issueFilterState.keyword = searchInput?searchInput.value:'';
  renderModule('issue');
}

